<% layout('layout/boilerplate') -%>

    <div class="mb-8">
        <nav class="flex mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path
                                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z">
                            </path>
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-slate-800 md:ml-2">New Case File</span>
                    </div>
                </li>
            </ol>
        </nav>
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Create New Case / नया केस बनाएं</h1>
        <p class="text-slate-500 mt-1">Enter details to initialize a new criminal investigation record</p>
    </div>

    <form action="/cases" method="POST" class="max-w-5xl mx-auto">

        <!-- Reporter Details -->
        <div class="card-premium p-8 mb-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">Reporter Details</h2>
                    <p class="text-sm text-slate-500">Who is reporting this incident? / रिपोर्टर का विवरण</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Full Name / रिपोर्टर का नाम <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="reporterName" class="form-input w-full" placeholder="e.g. Rajesh Kumar"
                        required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Contact Number / संपर्क नंबर <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="tel" id="reporterContact" name="reporterContact" class="form-input w-full"
                            placeholder="10-digit Mobile Number" pattern="[6-9]\d{9}" maxlength="10" required>
                        <div id="contactValidation" class="absolute right-3 top-1/2 -translate-y-1/2 hidden">
                            <!-- Icons injected via JS -->
                        </div>
                    </div>
                    <p class="text-xs text-slate-400 mt-1">Starting with 6-9</p>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Email Address / ईमेल</label>
                    <input type="email" name="reporterEmail" class="form-input w-full"
                        placeholder="e.g. rajesh@example.com">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">ID Type / पहचान प्रकार</label>
                    <select name="reporterIdType" class="form-input w-full">
                        <option value="" disabled selected>Select ID Type</option>
                        <option value="aadhar">Aadhar Card</option>
                        <option value="pan">PAN Card</option>
                        <option value="voter">Voter ID</option>
                        <option value="driving">Driving License</option>
                        <option value="passport">Passport</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">ID Number / पहचान संख्या</label>
                    <input type="text" name="reporterIdNumber" class="form-input w-full" placeholder="ID Number">
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Address / पता <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="reporterAddress" class="form-input w-full"
                        placeholder="House No, Street, Landmark" required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">City / शहर <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="reporterCity" class="form-input w-full" required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">District / जिला <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="reporterDistrict" class="form-input w-full" required>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">State / राज्य <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="reporterState" class="form-input w-full" required>
                </div>
            </div>
        </div>

        <!-- Case Information -->
        <div class="card-premium p-8 mb-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 011.414.586l5.414 5.414a1 1 0 01.586 1.414V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">Case Information</h2>
                    <p class="text-sm text-slate-500">Core details of the incident / केस की जानकारी</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Case Type / केस का प्रकार <span
                            class="text-red-500">*</span></label>
                    <select name="caseType" class="form-input w-full" required>
                        <option value="" disabled selected>Select Classification</option>
                        <option value="criminal">Criminal Case</option>
                        <option value="civil">Civil Case</option>
                        <option value="domestic">Domestic Violence</option>
                        <option value="cybercrime">Cybercrime</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Priority / प्राथमिकता <span
                            class="text-red-500">*</span></label>
                    <select name="priority" class="form-input w-full" required>
                        <option value="" disabled selected>Select Priority</option>
                        <option value="low">Low</option>
                        <option value="medium">Medium</option>
                        <option value="high">High</option>
                        <option value="urgent">Urgent</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Incident Date / घटना की तिथि <span
                            class="text-red-500">*</span></label>
                    <input type="date" name="incidentDate" class="form-input w-full" required>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Description / विवरण <span
                            class="text-red-500">*</span></label>
                    <textarea name="description" rows="4" class="form-input w-full"
                        placeholder="Provide a detailed description of the incident..." required></textarea>
                </div>
            </div>
        </div>

        <!-- Location Details -->
        <div class="card-premium p-8 mb-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                        </path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-slate-800">Incident Location</h2>
                    <p class="text-sm text-slate-500">Where did it happen? / घटना स्थल</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Address / पता <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="location" class="form-input w-full" placeholder="House No, Street, Area"
                        required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">City / शहर <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="city" class="form-input w-full" required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">District / जिला <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="district" class="form-input w-full" required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">State / राज्य <span
                            class="text-red-500">*</span></label>
                    <input type="text" name="state" class="form-input w-full" required>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-4 mb-20">
            <a href="/"
                class="px-6 py-3 rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-50 font-semibold transition-all">Cancel</a>
            <button type="submit"
                class="px-8 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold shadow-lg shadow-blue-500/30 transition-all transform hover:-translate-y-1">
                Create Case File
            </button>
        </div>

    </form>

    <script>
        // Validations
        const contactInput = document.getElementById('reporterContact');
        const contactValidation = document.getElementById('contactValidation');

        contactInput.addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);
            const isValid = /^[6-9]\d{9}$/.test(this.value);

            if (this.value.length > 0) {
                contactValidation.classList.remove('hidden');
                if (isValid) {
                    contactValidation.innerHTML = '<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
                    this.classList.remove('border-red-300', 'focus:border-red-500');
                    this.classList.add('border-green-300', 'focus:border-green-500');
                } else {
                    contactValidation.innerHTML = '<svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
                    this.classList.add('border-red-300', 'focus:border-red-500');
                    this.classList.remove('border-green-300', 'focus:border-green-500');
                }
            } else {
                contactValidation.classList.add('hidden');
                this.classList.remove('border-red-300', 'focus:border-red-500', 'border-green-300', 'focus:border-green-500');
            }
        });
    </script>