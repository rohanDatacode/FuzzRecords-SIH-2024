<% layout('layout/boilerplate') -%>

    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <nav class="flex mb-2" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-1 md:space-x-3">
                    <li class="inline-flex items-center">
                        <a href="/"
                            class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600">
                            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z">
                                </path>
                            </svg>
                            Dashboard
                        </a>
                    </li>
                    <li>
                        <div class="flex items-center">
                            <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="ml-1 text-sm font-medium text-slate-500 md:ml-2">Cases</span>
                        </div>
                    </li>
                    <li aria-current="page">
                        <div class="flex items-center">
                            <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="ml-1 text-sm font-medium text-slate-800 md:ml-2">#<%= caseData.caseNumber %>
                            </span>
                        </div>
                    </li>
                </ol>
            </nav>
            <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Case File: <%= caseData.caseNumber %>
            </h1>
        </div>

        <div class="flex items-center gap-3">
            <% if (caseData.status==='closed' ) { %>
                <button onclick="updateCaseStatus('active')"
                    class="inline-flex items-center px-4 py-2 bg-white border border-slate-300 rounded-lg font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm">
                    <svg class="w-4 h-4 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                        </path>
                    </svg>
                    Reopen Case
                </button>
                <% } else { %>
                    <button onclick="updateCaseStatus('closed')"
                        class="inline-flex items-center px-4 py-2 bg-white border border-slate-300 rounded-lg font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm">
                        <svg class="w-4 h-4 mr-2 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7">
                            </path>
                        </svg>
                        Close Case
                    </button>
                    <% } %>
                        <button onclick="window.print()"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition-colors shadow-sm">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2-4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z">
                                </path>
                            </svg>
                            Print Report
                        </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column: Main Info -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Case Description -->
            <div class="card-premium p-6">
                <div class="flex justify-between items-start mb-4">
                    <h2 class="text-xl font-bold text-slate-800">Incident Description</h2>
                    <span
                        class="badge <%= caseData.status === 'active' ? 'badge-green' : caseData.status === 'pending' ? 'badge-amber' : 'badge-red' %>">
                        <%= caseData.status.toUpperCase() %>
                    </span>
                </div>
                <div class="prose max-w-none text-slate-600">
                    <p class="font-medium text-slate-800">
                        <%= caseData.description.english %>
                    </p>
                    <p class="text-slate-500 mt-2 text-sm italic">
                        <%= caseData.description.hindi %>
                    </p>
                </div>
            </div>

            <!-- Connected Profiles -->
            <div class="card-premium p-6">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-slate-800">Involved Persons</h2>
                    <button onclick="showProfileLinkModal()"
                        class="text-sm font-semibold text-blue-600 hover:text-blue-800 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition-colors">
                        + Link Profile
                    </button>
                </div>

                <div class="space-y-4">
                    <% if (caseData.profiles && caseData.profiles.length> 0) { %>
                        <% caseData.profiles.forEach(profile=> { %>
                            <div
                                class="border border-slate-200 rounded-xl p-4 hover:border-blue-300 transition-colors bg-slate-50/50">
                                <div class="flex justify-between items-start">
                                    <div class="flex items-start space-x-4">
                                        <div
                                            class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-bold text-slate-700 shadow-sm">
                                            <%= profile.profile.firstNameEnglish.charAt(0) %>
                                        </div>
                                        <div>
                                            <h3 class="font-bold text-slate-800">
                                                <%= profile.profile.firstNameEnglish %>
                                                    <%= profile.profile.lastNameEnglish %>
                                            </h3>
                                            <span class="badge mt-1 <%= 
                                            profile.role === 'accused' ? 'badge-red' : 
                                            profile.role === 'victim' ? 'badge-amber' : 
                                            'badge-blue' %>">
                                                <%= profile.role.toUpperCase() %>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="flex space-x-2">
                                        <a href="/record/<%= profile.profile._id %>"
                                            class="text-xs font-medium text-slate-500 hover:text-blue-600 border border-slate-200 px-2 py-1 rounded hover:bg-white transition-all">View</a>
                                        <button onclick="unlinkProfile('<%= profile.profile._id %>')"
                                            class="text-xs font-medium text-red-500 hover:text-red-700 border border-slate-200 px-2 py-1 rounded hover:bg-white transition-all">Unlink</button>
                                    </div>
                                </div>

                                <% if (profile.details) { %>
                                    <div
                                        class="mt-3 text-sm text-slate-600 bg-white p-3 rounded-lg border border-slate-100">
                                        <span class="font-semibold text-slate-700">Statement:</span>
                                        <%= profile.details %>
                                    </div>
                                    <% } %>

                                        <% if (profile.articles && profile.articles.length> 0) { %>
                                            <div class="mt-3 flex flex-wrap gap-2">
                                                <% profile.articles.forEach(article=> { %>
                                                    <span
                                                        class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-slate-200 text-slate-700">
                                                        Section: <%= article.section %>
                                                    </span>
                                                    <% }) %>
                                            </div>
                                            <% } %>

                                                <!-- Arrest & Court details can be collapsible or simplified here -->
                                                <% if (profile.role==='accused' && profile.arrestDetails &&
                                                    profile.arrestDetails.isArrested) { %>
                                                    <div
                                                        class="mt-3 grid grid-cols-2 gap-4 text-xs bg-red-50 p-3 rounded-lg border border-red-100">
                                                        <div>
                                                            <span class="block text-red-800 font-semibold">Arrest
                                                                Date</span>
                                                            <span class="text-red-700">
                                                                <%= new
                                                                    Date(profile.arrestDetails.arrestDate).toLocaleDateString()
                                                                    %>
                                                            </span>
                                                        </div>
                                                        <div>
                                                            <span
                                                                class="block text-red-800 font-semibold">Officer</span>
                                                            <span class="text-red-700">
                                                                <%= profile.arrestDetails.arrestingOfficer %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <% } %>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div
                                        class="text-center py-8 bg-slate-50 rounded-xl border border-dashed border-slate-300">
                                        <p class="text-slate-500">No involved persons linked yet.</p>
                                        <button onclick="showProfileLinkModal()"
                                            class="text-blue-600 font-medium hover:underline mt-2">Link a
                                            profile</button>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </div>

        <!-- Right Column: Sidebar -->
        <div class="lg:col-span-1 space-y-6">

            <!-- Reporter Info -->
            <div class="card-premium p-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Reporting Officer</h3>
                <div class="flex items-center space-x-3 mb-4">
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-slate-800">
                            <%= caseData.reporter.name.english %>
                        </p>
                        <p class="text-xs text-slate-500">
                            <%= caseData.reporter.name.hindi %>
                        </p>
                    </div>
                </div>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between border-b border-slate-100 pb-2">
                        <span class="text-slate-500">Contact</span>
                        <span class="text-slate-700 font-medium">
                            <%= caseData.reporter.contact %>
                        </span>
                    </div>
                    <% if (caseData.reporter.email) { %>
                        <div class="flex justify-between pt-2">
                            <span class="text-slate-500">Email</span>
                            <span class="text-slate-700 font-medium">
                                <%= caseData.reporter.email %>
                            </span>
                        </div>
                        <% } %>
                </div>
            </div>

            <!-- Location Info -->
            <div class="card-premium p-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Location</h3>
                <div class="flex items-start space-x-3">
                    <div class="mt-1 text-red-500">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                            </path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                    </div>
                    <div class="text-sm">
                        <p class="font-bold text-slate-800">
                            <%= caseData.location.city.english %>, <%= caseData.location.state.english %>
                        </p>
                        <p class="text-slate-600 mt-1">
                            <%= caseData.location.address.english %>
                        </p>
                        <p class="text-slate-400 text-xs mt-1">
                            <%= caseData.location.address.hindi %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Timeline -->
            <div class="card-premium p-6">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">Timeline</h3>
                <div class="border-l-2 border-slate-200 ml-2 space-y-6">
                    <% caseData.timeline.forEach(entry=> { %>
                        <div class="relative pl-6">
                            <div
                                class="absolute -left-[5px] top-1.5 w-3 h-3 bg-white border-2 border-blue-500 rounded-full">
                            </div>
                            <p class="text-xs font-semibold text-blue-600">
                                <%= new Date(entry.date).toLocaleDateString() %>
                            </p>
                            <p class="text-sm font-medium text-slate-800 mt-0.5">
                                <%= entry.description.english %>
                            </p>
                            <p class="text-xs text-slate-500 mt-0.5">
                                <%= entry.description.hindi %>
                            </p>
                        </div>
                        <% }) %>
                </div>
            </div>

        </div>
    </div>

    <!-- Link Profile Modal (Refactored for Light Theme) -->
    <div id="profileLinkModal" class="fixed inset-0 bg-slate-900/50 hidden z-50 backdrop-blur-sm transition-opacity">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="bg-white rounded-2xl shadow-xl p-6 max-w-2xl w-full">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-bold text-slate-800">Link Profile to Case</h2>
                    <button onclick="hideProfileLinkModal()" class="text-slate-400 hover:text-slate-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <div class="mb-6">
                    <input type="text" id="profileSearch" placeholder="Search profiles by name..."
                        class="form-input w-full">
                </div>

                <div id="profileSearchResults" class="max-h-80 overflow-y-auto space-y-3 pr-2">
                    <!-- Search results will appear here -->
                </div>
            </div>
        </div>
    </div>

    <!-- SCRIPTS (Reused Logic, Updated Selectors/Classes if needed) -->
    <script>
        function showProfileLinkModal() {
            document.getElementById('profileLinkModal').classList.remove('hidden');
        }

        function hideProfileLinkModal() {
            document.getElementById('profileLinkModal').classList.add('hidden');
        }

        // Profile search functionality
        document.getElementById('profileSearch').addEventListener('input', async function (e) {
            const searchTerm = e.target.value.trim();
            const resultsDiv = document.getElementById('profileSearchResults');

            if (searchTerm.length < 2) {
                resultsDiv.innerHTML = '';
                return;
            }

            try {
                const response = await fetch(`/api/profiles/search?q=${encodeURIComponent(searchTerm)}`);
                if (!response.ok) throw new Error('Search failed');

                const data = await response.json();

                if (!data.profiles || data.profiles.length === 0) {
                    resultsDiv.innerHTML = `
                <div class="text-center text-slate-400 py-6">
                    <p>No profiles found matching "${searchTerm}"</p>
                </div>
            `;
                    return;
                }

                resultsDiv.innerHTML = data.profiles.map(profile => `
            <div class="border border-slate-200 rounded-xl p-4 hover:border-blue-400 transition-colors">
                <div class="flex justify-between items-start">
                    <div>
                        <p class="font-bold text-slate-800">${profile.firstNameEnglish} ${profile.lastNameEnglish}</p>
                        <p class="text-sm text-slate-500">ID: ${profile.id}</p>
                    </div>
                    <div class="flex space-x-2">
                        <button onclick="toggleAdditionalDetails('${profile._id}')" id="toggle-details-${profile._id}" class="text-sm text-blue-600 hover:text-blue-800 font-medium px-3 py-1 rounded hover:bg-blue-50">Details</button>
                        <button onclick="validateAndLink('${profile._id}')" id="link-button-${profile._id}" class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-1 rounded shadow-sm">Link</button>
                    </div>
                </div>

                <!-- Form Fields -->
                <div class="mt-4 space-y-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Role <span class="text-red-500">*</span></label>
                        <select id="role-${profile._id}" required class="form-input w-full py-1 text-sm">
                            <option value="">Select Role</option>
                            <option value="accused">Accused</option>
                            <option value="victim">Victim</option>
                            <option value="witness">Witness</option>
                            <option value="complainant">Complainant</option>
                        </select>
                    </div>

                    <div id="additional-details-${profile._id}" class="hidden space-y-3 pt-2 border-t border-slate-100">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Case Details <span class="text-red-500">*</span></label>
                            <textarea id="details-${profile._id}" required placeholder="Enter statement or involvement details..." class="form-input w-full h-20 resize-none text-sm"></textarea>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Section/Articles <span class="text-red-500">*</span></label>
                            <div class="flex space-x-2">
                                <input type="text" id="article-${profile._id}" placeholder="e.g. 302" class="form-input flex-1 text-sm">
                                <button onclick="addArticle('${profile._id}')" class="bg-slate-100 hover:bg-slate-200 text-slate-600 px-3 rounded text-sm mb-[1px]">Add</button>
                            </div>
                            <div id="articles-list-${profile._id}" class="mt-2 flex flex-wrap gap-2"></div>
                            <p id="articles-error-${profile._id}" class="hidden text-red-500 text-xs mt-1">Required</p>
                        </div>
                        
                        <!-- Arrest Details (Conditional) -->
                        <div id="arrest-details-${profile._id}" class="hidden bg-red-50 p-3 rounded-lg border border-red-100">
                             <label class="flex items-center space-x-2 mb-2">
                                <input type="checkbox" id="is-arrested-${profile._id}" class="rounded text-red-600 focus:ring-red-500 border-gray-300">
                                <span class="text-sm font-medium text-red-800">Has been arrested?</span>
                            </label>
                            <div id="arrest-fields-${profile._id}" class="space-y-2">
                                <input type="date" id="arrest-date-${profile._id}" class="form-input w-full text-sm" disabled required>
                                <input type="text" id="arrest-location-${profile._id}" placeholder="Location" class="form-input w-full text-sm" disabled required>
                                <input type="text" id="arresting-officer-${profile._id}" placeholder="Officer Name" class="form-input w-full text-sm" disabled required>
                            </div>
                        </div>

                        <!-- Court Details -->
                        <div class="bg-slate-50 p-3 rounded-lg border border-slate-200">
                            <h4 class="text-xs font-bold text-slate-500 uppercase mb-2">Court Info <span class="text-red-500">*</span></h4>
                            <div class="grid grid-cols-2 gap-2">
                                <input type="text" id="court-name-${profile._id}" placeholder="Court Name" required class="form-input w-full text-sm">
                                <input type="text" id="court-case-number-${profile._id}" placeholder="Case No." required class="form-input w-full text-sm">
                                <input type="date" id="next-hearing-${profile._id}" required class="form-input w-full text-sm">
                                <input type="text" id="judge-name-${profile._id}" placeholder="Judge" required class="form-input w-full text-sm">
                                <select id="court-status-${profile._id}" required class="form-input w-full text-sm col-span-2">
                                    <option value="">Select Status</option>
                                    <option value="pending">Pending</option>
                                    <option value="ongoing">Ongoing</option>
                                    <option value="disposed">Disposed</option>
                                    <option value="appealed">Appealed</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
            } catch (error) {
                console.error('Search error:', error);
                resultsDiv.innerHTML = `<div class="text-center text-red-500 py-4"><p>Error searching: ${error.message}</p></div>`;
            }
        });

        // Reuse existing validation logic but adapted for standard inputs
        function validateFields(profileId) {
            const role = document.getElementById(`role-${profileId}`);
            const detailsSection = document.getElementById(`additional-details-${profileId}`);
            const errors = [];

            if (!role.value) {
                errors.push('Role is required');
                role.classList.add('border-red-500');
            } else {
                role.classList.remove('border-red-500');
            }

            if (!detailsSection.classList.contains('hidden')) {
                const details = document.getElementById(`details-${profileId}`);
                if (!details.value.trim()) {
                    errors.push('Case details are required');
                    details.classList.add('border-red-500');
                } else {
                    details.classList.remove('border-red-500');
                }

                const articles = document.getElementById(`articles-list-${profileId}`).children;
                const articleInput = document.getElementById(`article-${profileId}`);
                if (articles.length === 0) {
                    errors.push('At least one section is required');
                    articleInput.classList.add('border-red-500');
                } else {
                    articleInput.classList.remove('border-red-500');
                }

                // Add detailed validations here as needed...
            }
            return errors;
        }

        // Reuse linkage logic
        async function validateAndLink(profileId) {
            const errors = validateFields(profileId);
            if (errors.length > 0) {
                alert('Please fix errors:\n' + errors.join('\n'));
                return;
            }
            await linkProfile(profileId);
        }

        // Toggle details visibility
        function toggleAdditionalDetails(profileId) {
            const section = document.getElementById(`additional-details-${profileId}`);
            const btn = document.getElementById(`toggle-details-${profileId}`);
            if (section.classList.contains('hidden')) {
                section.classList.remove('hidden');
                btn.innerText = 'Hide Details';
            } else {
                section.classList.add('hidden');
                btn.innerText = 'Fill Details';
            }
        }

        // Role change listener for Arrest Details
        document.addEventListener('change', function (e) {
            if (e.target && e.target.id.startsWith('role-')) {
                const profileId = e.target.id.split('-')[1];
                const arrestSection = document.getElementById(`arrest-details-${profileId}`);
                if (arrestSection) {
                    if (e.target.value === 'accused') {
                        arrestSection.classList.remove('hidden');
                    } else {
                        arrestSection.classList.add('hidden');
                    }
                }
            }

            // Arrest Checkbox listener
            if (e.target && e.target.id.startsWith('is-arrested-')) {
                const profileId = e.target.id.split('-')[2];
                const inputs = document.getElementById(`arrest-fields-${profileId}`).querySelectorAll('input');
                inputs.forEach(input => {
                    input.disabled = !e.target.checked;
                    if (e.target.checked) input.setAttribute('required', '');
                    else input.removeAttribute('required');
                });
            }
        });

        function addArticle(profileId) {
            const input = document.getElementById(`article-${profileId}`);
            const list = document.getElementById(`articles-list-${profileId}`);
            const val = input.value.trim();
            if (val) {
                const span = document.createElement('span');
                span.className = 'inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-700';
                span.innerHTML = `<span>${val}</span><button type="button" onclick="this.parentElement.remove()" class="ml-1 text-blue-400 hover:text-blue-600">×</button>`;
                list.appendChild(span);
                input.value = '';
            }
        }

        // Link Profile Function
        async function linkProfile(profileId) {
            try {
                const role = document.getElementById(`role-${profileId}`).value;
                const details = document.getElementById(`details-${profileId}`).value;
                const articles = Array.from(document.getElementById(`articles-list-${profileId}`).children)
                    .map(el => ({ section: el.querySelector('span').textContent }));

                // Collect other details (court, arrest)...
                // Simplified for brevity, assume similar collection logic as before but adapted

                const courtDetails = {
                    courtName: document.getElementById(`court-name-${profileId}`).value,
                    caseNumber: document.getElementById(`court-case-number-${profileId}`).value,
                    nextHearingDate: document.getElementById(`next-hearing-${profileId}`).value,
                    judgeName: document.getElementById(`judge-name-${profileId}`).value,
                    status: document.getElementById(`court-status-${profileId}`).value
                };

                const arrestDetailsArg = (role === 'accused' && document.getElementById(`is-arrested-${profileId}`).checked) ? {
                    isArrested: true,
                    arrestDate: document.getElementById(`arrest-date-${profileId}`).value,
                    arrestLocation: { english: document.getElementById(`arrest-location-${profileId}`).value },
                    arrestingOfficer: document.getElementById(`arresting-officer-${profileId}`).value
                } : undefined;

                const btn = document.getElementById(`link-button-${profileId}`);
                btn.textContent = 'Linking...';
                btn.disabled = true;

                const response = await fetch(`/api/cases/<%= caseData._id %>/profiles`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ profileId, role, details, articles, courtDetails, arrestDetails: arrestDetailsArg })
                });

                if (!response.ok) throw new Error('Failed');
                window.location.reload();

            } catch (e) {
                alert('Error: ' + e.message);
                document.getElementById(`link-button-${profileId}`).disabled = false;
            }
        }

        async function unlinkProfile(profileId) {
            if (!confirm('Unlink this profile?')) return;
            try {
                const res = await fetch(`/api/cases/<%= caseData._id %>/profiles/${profileId}`, { method: 'DELETE' });
                if (res.ok) window.location.reload();
            } catch (e) { console.error(e); }
        }

        async function updateCaseStatus(status) {
            if (!confirm('Change case status?')) return;
            try {
                const res = await fetch(`/cases/<%= caseData._id %>/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
                if (res.ok) window.location.reload();
            } catch (e) { console.error(e); }
        }
    </script>