                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
                <h1 class="text-xl font-bold tracking-wide text-white">FuzzRecords</h1>
            </a>

            <!-- Right: Dynamic Links -->
            <div class="hidden md:flex items-center space-x-4 text-white">
                
                <% if (!currentUser) { %>
                    <!-- GUEST NAVBAR -->
                    <a href="/login" class="px-3 py-2 text-sm font-medium text-white hover:underline">Login</a>
                    <a href="/register"
                        class="bg-white text-brand-blue px-4 py-2 rounded-md text-sm font-bold hover:bg-blue-50 transition-all">
                        Register
                    </a>
                
                <% } else { %>
                    <!-- LOGGED IN NAVBAR -->
                    <a href="/" class="px-3 py-2 text-sm font-medium text-white hover:underline">Dashboard</a>
                    <a href="/search" class="px-3 py-2 text-sm font-medium text-white hover:underline">Search</a>
                    <a href="/face-search" class="px-3 py-2 text-sm font-medium text-white hover:underline">Face ID</a>

