<% layout('./layout/boilerplate') -%>

    <div class="mb-8">
        <nav class="flex mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path
                                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z">
                            </path>
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li class="inline-flex items-center">
                    <a href="/newrecord"
                        class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600">
                        <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        Create Profile
                    </a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-slate-800 md:ml-2">Preview</span>
                    </div>
                </li>
            </ol>
        </nav>
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Review Profile Data</h1>
                <p class="text-slate-500 mt-1">Verify all information before final submission</p>
            </div>
            <div class="flex gap-3">
                <button onclick="history.back()"
                    class="px-5 py-2.5 rounded-xl border border-blue-200 text-blue-600 hover:bg-blue-50 font-semibold transition-all flex items-center shadow-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z"></path>
                    </svg>
                    Edit Details
                </button>
                <form action="/newrecord/submit" method="POST" id="submitForm" class="inline">
                    <%# --- Server-side hidden inputs (guaranteed to be present) --- %>
                        <input type="hidden" name="firstName" value="<%= formData.firstName || '' %>">
                        <input type="hidden" name="middleName" value="<%= formData.middleName || '' %>">
                        <input type="hidden" name="lastName" value="<%= formData.lastName || '' %>">
                        <input type="hidden" name="occupation" value="<%= formData.occupation || '' %>">
                        <input type="hidden" name="dob" value="<%= formData.dob || '' %>">
                        <input type="hidden" name="gender" value="<%= formData.gender || '' %>">
                        <input type="hidden" name="mNumber" value="<%= formData.mNumber || '' %>">
                        <input type="hidden" name="aadharNumber" value="<%= formData.aadharNumber || '' %>">
                        <input type="hidden" name="description" value="<%= formData.description || '' %>">
                        <input type="hidden" name="role" value="<%= formData.role || '' %>">
                        <%# Address fields %>
                            <input type="hidden" name="address[location]"
                                value="<%= formData.address?.location || '' %>">
                            <input type="hidden" name="address[city]" value="<%= formData.address?.city || '' %>">
                            <input type="hidden" name="address[district]"
                                value="<%= formData.address?.district || '' %>">
                            <input type="hidden" name="address[state]" value="<%= formData.address?.state || '' %>">
                            <%# Appearance fields %>
                                <input type="hidden" name="appearance[height]"
                                    value="<%= formData.appearance?.height || '' %>">
                                <input type="hidden" name="appearance[weight]"
                                    value="<%= formData.appearance?.weight || '' %>">
                                <input type="hidden" name="appearance[build]"
                                    value="<%= formData.appearance?.build || '' %>">
                                <input type="hidden" name="appearance[complexion]"
                                    value="<%= formData.appearance?.complexion || '' %>">
                                <input type="hidden" name="appearance[facialFeatures]"
                                    value="<%= formData.appearance?.facialFeatures || '' %>">
                                <input type="hidden" name="appearance[scars]"
                                    value="<%= formData.appearance?.scars || '' %>">
                                <input type="hidden" name="appearance[tattoos]"
                                    value="<%= formData.appearance?.tattoos || '' %>">
                                <input type="hidden" name="faceDescriptor" value="<%= formData.faceDescriptor || '' %>">
                                <button type="submit"
                                    class="px-6 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 text-white font-bold shadow-lg shadow-green-500/30 transition-all flex items-center transform hover:-translate-y-0.5">
                                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M5 13l4 4L19 7">
                                        </path>
                                    </svg>
                                    Confirm & Submit
                                </button>
                </form>
            </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto space-y-8 pb-20">

        <!-- Preview Banner -->
        <div
            class="bg-blue-50 border border-blue-100 rounded-xl p-4 flex items-center justify-center text-blue-700 shadow-sm">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-medium">Preview Mode - Data is not yet saved to the database</span>
        </div>

        <!-- Profile Header -->
        <div class="card-premium p-8">
            <div class="flex flex-col md:flex-row md:items-start gap-8">
                <div class="flex-shrink-0 relative group">
                    <div
                        class="w-40 h-40 rounded-full border-4 border-white shadow-xl overflow-hidden hover:scale-105 transition-transform duration-300">
                        <img src="<%= formData.uploadedFiles?.profileImage?.[0]?.path || '/images/default-profile.png' %>"
                            alt="Profile Photo" class="w-full h-full object-cover"
                            onerror="this.src='/images/default-profile.png'">
                    </div>
                    <% if (formData.uploadedFiles?.profileImage?.[0]) { %>
                        <div
                            class="absolute bottom-2 right-2 bg-white text-blue-600 rounded-full p-2 shadow-lg border border-blue-50">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z">
                                </path>
                            </svg>
                        </div>
                        <% } %>
                </div>

                <div class="flex-grow space-y-4">
                    <div>
                        <h2 class="text-3xl font-bold text-slate-800">
                            <%= formData.firstName || '' %> <span class="text-slate-500 font-normal">
                                    <%= formData.middleName || '' %>
                                </span>
                                <%= formData.lastName || '' %>
                        </h2>
                        <p class="text-lg text-blue-600 font-medium">
                            <%= formData.occupation || 'Occupation Not Specified' %>
                        </p>
                    </div>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 pt-4 border-t border-slate-100">
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Date of Birth</p>
                            <p class="text-slate-800 font-medium mt-1">
                                <%= formData.dob ? new Date(formData.dob).toLocaleDateString() : 'N/A' %>
                            </p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Gender</p>
                            <p class="text-slate-800 font-medium mt-1 uppercase">
                                <%= formData.gender || 'N/A' %>
                            </p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Mobile Number</p>
                            <p class="text-slate-800 font-medium mt-1 font-mono">
                                <%= formData.mNumber || 'N/A' %>
                            </p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Aadhar ID</p>
                            <p class="text-slate-800 font-medium mt-1 font-mono tracking-wide">
                                <%= formData.aadharNumber || 'N/A' %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            <!-- Address Info -->
            <div class="card-premium p-8 h-full">
                <h3 class="text-lg font-bold text-slate-800 mb-6 flex items-center">
                    <span
                        class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 mr-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                            </path>
                        </svg>
                    </span>
                    Address Details
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between border-b border-slate-50 pb-2">
                        <span class="text-slate-500">Location</span>
                        <span class="text-slate-800 font-medium text-right">
                            <%= formData.address?.location || 'N/A' %>
                        </span>
                    </div>
                    <div class="flex justify-between border-b border-slate-50 pb-2">
                        <span class="text-slate-500">City</span>
                        <span class="text-slate-800 font-medium text-right">
                            <%= formData.address?.city || 'N/A' %>
                        </span>
                    </div>
                    <div class="flex justify-between border-b border-slate-50 pb-2">
                        <span class="text-slate-500">District</span>
                        <span class="text-slate-800 font-medium text-right">
                            <%= formData.address?.district || 'N/A' %>
                        </span>
                    </div>
                    <div class="flex justify-between pb-2">
                        <span class="text-slate-500">State</span>
                        <span class="text-slate-800 font-medium text-right">
                            <%= formData.address?.state || 'N/A' %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Physical Appearance -->
            <div class="card-premium p-8 h-full">
                <h3 class="text-lg font-bold text-slate-800 mb-6 flex items-center">
                    <span
                        class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 mr-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </span>
                    Physical Appearance
                </h3>
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-slate-50 p-3 rounded-lg text-center">
                        <span class="block text-xs text-slate-400 uppercase">Height</span>
                        <span class="font-bold text-slate-800">
                            <%= formData.appearance?.height ? formData.appearance.height + ' cm' : 'N/A' %>
                        </span>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg text-center">
                        <span class="block text-xs text-slate-400 uppercase">Weight</span>
                        <span class="font-bold text-slate-800">
                            <%= formData.appearance?.weight ? formData.appearance.weight + ' kg' : 'N/A' %>
                        </span>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg text-center">
                        <span class="block text-xs text-slate-400 uppercase">Build</span>
                        <span class="font-bold text-slate-800">
                            <%= formData.appearance?.build || 'N/A' %>
                        </span>
                    </div>
                    <div class="bg-slate-50 p-3 rounded-lg text-center">
                        <span class="block text-xs text-slate-400 uppercase">Complexion</span>
                        <span class="font-bold text-slate-800">
                            <%= formData.appearance?.complexion || 'N/A' %>
                        </span>
                    </div>
                </div>

                <% if (formData.appearance?.facialFeatures || formData.appearance?.scars ||
                    formData.appearance?.tattoos) { %>
                    <div class="space-y-3">
                        <p class="text-xs font-bold text-slate-400 uppercase">Distinguishing Marks</p>
                        <% if (formData.appearance?.facialFeatures) { %>
                            <div class="text-sm text-slate-600 flex items-baseline"><span
                                    class="w-4 h-4 mr-2 bg-purple-100 rounded-full flex-shrink-0"></span>
                                <%= formData.appearance.facialFeatures %>
                            </div>
                            <% } %>
                                <% if (formData.appearance?.scars) { %>
                                    <div class="text-sm text-slate-600 flex items-baseline"><span
                                            class="w-4 h-4 mr-2 bg-purple-100 rounded-full flex-shrink-0"></span>
                                        <%= formData.appearance.scars %>
                                    </div>
                                    <% } %>
                                        <% if (formData.appearance?.tattoos) { %>
                                            <div class="text-sm text-slate-600 flex items-baseline"><span
                                                    class="w-4 h-4 mr-2 bg-purple-100 rounded-full flex-shrink-0"></span>
                                                <%= formData.appearance.tattoos %>
                                            </div>
                                            <% } %>
                    </div>
                    <% } %>
            </div>
        </div>

        <!-- ID Documents -->
        <div class="card-premium p-8">
            <h3 class="text-lg font-bold text-slate-800 mb-6 flex items-center">
                <span class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 mr-3">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2">
                        </path>
                    </svg>
                </span>
                Identity Documents
            </h3>

            <% if (formData.uploadedFiles?.idProof?.[0]) { %>
                <div class="border rounded-xl p-4 bg-slate-50 inline-block">
                    <img src="<%= formData.uploadedFiles.idProof[0].path %>" alt="ID Proof"
                        class="h-48 w-auto object-cover rounded-lg shadow-sm hover:scale-105 transition-transform cursor-pointer"
                        onclick="window.open(this.src, '_blank')" onerror="this.src='/images/default-document.png'">
                    <p class="text-center text-xs text-slate-500 mt-2 font-medium">Click to View Original</p>
                </div>
                <% } else { %>
                    <div class="p-8 border-2 border-dashed border-slate-200 rounded-xl text-center text-slate-400">
                        No ID Documents Uploaded
                    </div>
                    <% } %>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            console.log('Preview page loaded. Data is stored in hidden form fields via server-side EJS.');
        });
    </script>