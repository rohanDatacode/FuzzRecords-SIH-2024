<% layout('layout/boilerplate') -%>

    <!-- Hero Section: Premium Gradient -->
    <div class="relative overflow-hidden bg-gradient-hero rounded-3xl p-8 md:p-12 mb-10 shadow-lg text-white">
        <div class="relative z-10 flex flex-col md:flex-row justify-between items-center">
            <div>
                <h1 class="text-4xl font-bold tracking-tight mb-2">Welcome to FuzzRecords</h1>
                <p class="text-blue-100 text-lg opacity-90">Intelligence Management System v2.0</p>
                <div class="flex items-center space-x-4 mt-6">
                    <span
                        class="inline-flex items-center px-3 py-1 rounded-full bg-blue-500/30 border border-blue-400/30 text-sm backdrop-blur-sm">
                        <span class="w-2 h-2 rounded-full bg-green-400 mr-2 animate-pulse"></span>
                        System Operational
                    </span>
                    <span class="text-sm text-blue-200">
                        <%= new Date().toLocaleDateString('en-US', { weekday: 'long' , year: 'numeric' , month: 'long' ,
                            day: 'numeric' }) %>
                    </span>
                </div>
            </div>

            <!-- Hero Quick Stats -->
            <div
                class="mt-8 md:mt-0 flex space-x-8 bg-white/10 backdrop-blur-md p-6 rounded-2xl border border-white/10">
                <div class="text-center">
                    <p class="text-3xl font-bold">
                        <%= stats.activeCases %>
                    </p>
                    <p class="text-xs text-blue-200 uppercase tracking-wider mt-1">Active Cases</p>
                </div>
                <div class="w-px bg-white/20"></div>
                <div class="text-center">
                    <p class="text-3xl font-bold text-amber-300">
                        <%= stats.pendingCases %>
                    </p>
                    <p class="text-xs text-blue-200 uppercase tracking-wider mt-1">Pending alerts</p>
                </div>
            </div>
        </div>

        <!-- Decorative Background Circles -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-60 h-60 bg-blue-500/20 rounded-full blur-3xl"></div>
    </div>

    <!-- Primary Actions -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
        <a href="/cases/new" class="card-premium p-6 group hover:bg-blue-50/50 cursor-pointer">
            <div
                class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-800 group-hover:text-blue-700">New Case File</h3>
            <p class="text-slate-500 text-sm mt-1">Initialize a new criminal investigation record</p>
        </a>

        <a href="/newrecord" class="card-premium p-6 group hover:bg-green-50/50 cursor-pointer">
            <div
                class="w-12 h-12 rounded-xl bg-green-100 text-green-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-800 group-hover:text-green-700">Add Profile</h3>
            <p class="text-slate-500 text-sm mt-1">Create a new subject profile in the database</p>
        </a>

        <a href="/search" class="card-premium p-6 group hover:bg-indigo-50/50 cursor-pointer">
            <div
                class="w-12 h-12 rounded-xl bg-indigo-100 text-indigo-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-800 group-hover:text-indigo-700">Search Records</h3>
            <p class="text-slate-500 text-sm mt-1">Advanced search using Name, ID, or Biometrics</p>
        </a>

        <a href="/analytics" class="card-premium p-6 group hover:bg-purple-50/50 cursor-pointer">
            <div
                class="w-12 h-12 rounded-xl bg-purple-100 text-purple-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                    </path>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-800 group-hover:text-purple-700">Analytics</h3>
            <p class="text-slate-500 text-sm mt-1">Visualize data trends and department statistics</p>
        </a>
    </div>

    <!-- Detailed Statistics Section -->
    <div class="card-premium p-8 mb-12">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-800">Database Overview</h2>
            <span class="text-sm text-slate-500">Last updated: Just now</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 divide-y md:divide-y-0 md:divide-x divide-slate-100">
            <div class="text-center md:text-left pt-4 md:pt-0">
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Total Profiles</p>
                <p class="text-4xl font-extrabold text-slate-800 mt-2">
                    <%= stats.totalRecords %>
                </p>
                <p class="text-sm text-green-600 mt-1 font-medium bg-green-50 inline-block px-2 py-0.5 rounded-full">+
                    <%= stats.monthlyRecords %> this month
                </p>
            </div>
            <div class="text-center md:text-left pt-4 md:pt-0 md:pl-8">
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Total Cases</p>
                <p class="text-4xl font-extrabold text-slate-800 mt-2">
                    <%= stats.totalCases %>
                </p>
                <p class="text-sm text-blue-600 mt-1 font-medium bg-blue-50 inline-block px-2 py-0.5 rounded-full">+<%=
                        stats.monthlyCases %> this month</p>
            </div>
            <div class="text-center md:text-left pt-4 md:pt-0 md:pl-8">
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Solved Cases</p>
                <p class="text-4xl font-extrabold text-slate-800 mt-2">
                    <%= stats.closedCases %>
                </p>
                <p class="text-sm text-slate-500 mt-1">Successfully resolved</p>
            </div>
            <div class="text-center md:text-left pt-4 md:pt-0 md:pl-8">
                <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Verified IDs</p>
                <p class="text-4xl font-extrabold text-slate-800 mt-2">
                    <%= stats.profilesWithAadhar %>
                </p>
                <p class="text-sm text-purple-600 mt-1 font-medium bg-purple-50 inline-block px-2 py-0.5 rounded-full">
                    Aadhar Linked</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Recent Profiles Table -->
        <div class="card-premium overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-gray-50/50">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-6 bg-blue-500 rounded-full"></div>
                    <h3 class="font-bold text-slate-800 text-lg">Recent Profiles</h3>
                </div>
                <a href="/search" class="text-sm font-semibold text-blue-600 hover:text-blue-800 hover:underline">View
                    All</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 text-slate-500 uppercase text-xs tracking-wider">
                            <th class="px-6 py-3 font-semibold text-left">Subject</th>
                            <th class="px-6 py-3 font-semibold text-left">Location</th>
                            <th class="px-6 py-3 font-semibold text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (recentRecords && recentRecords.length> 0) { %>
                            <% recentRecords.forEach(record=> { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center">
                                            <div
                                                class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-lg mr-3">
                                                <%= record.firstNameEnglish.charAt(0) %>
                                            </div>
                                            <div>
                                                <div class="font-bold text-slate-800">
                                                    <%= record.firstNameEnglish %>
                                                        <%= record.lastNameEnglish %>
                                                </div>
                                                <div class="text-xs text-slate-500 font-mono">ID: #<%=
                                                        record.id.toString().slice(-6).toUpperCase() %>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-slate-600">
                                        <span class="inline-flex items-center">
                                            <svg class="w-4 h-4 mr-1 text-slate-400" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                                </path>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            </svg>
                                            <%= record.address.cityEnglish || 'Unknown' %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <a href="/record/<%= record.id %>"
                                            class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white border border-slate-200 text-slate-400 hover:text-blue-600 hover:border-blue-600 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M9 5l7 7-7 7"></path>
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3" class="px-6 py-10 text-center text-slate-400">
                                                No records found. Start by adding a new profile.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Cases Table -->
        <div class="card-premium overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-gray-50/50">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-6 bg-amber-500 rounded-full"></div>
                    <h3 class="font-bold text-slate-800 text-lg">Recent Cases</h3>
                </div>
                <a href="/cases/search"
                    class="text-sm font-semibold text-amber-600 hover:text-amber-800 hover:underline">View All</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-gray-50 text-slate-500 uppercase text-xs tracking-wider">
                            <th class="px-6 py-3 font-semibold text-left">Case ID</th>
                            <th class="px-6 py-3 font-semibold text-left">Status</th>
                            <th class="px-6 py-3 font-semibold text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <% if (recentCases && recentCases.length> 0) { %>
                            <% recentCases.forEach(case_=> { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4">
                                        <div class="font-bold text-slate-800">#<%= case_.caseNumber %>
                                        </div>
                                        <div class="text-xs text-slate-500">
                                            <%= case_.caseType %>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="badge 
                                    <%= case_.status === 'active' ? 'badge-amber' : 
                                        case_.status === 'pending' ? 'badge-red' : 
                                        'badge-green' %>">
                                            <%= case_.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <a href="/cases/<%= case_._id %>"
                                            class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white border border-slate-200 text-slate-400 hover:text-blue-600 hover:border-blue-600 transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M9 5l7 7-7 7"></path>
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3" class="px-6 py-10 text-center text-slate-400">
                                                No recent cases.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>