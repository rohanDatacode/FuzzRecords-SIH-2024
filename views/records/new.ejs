<% layout('./layout/boilerplate') -%>

    <style>
        /* Voice Search Animation */
        @keyframes micPulse {
            0% {
                transform: scale(1);
                opacity: 1;
            }

            50% {
                transform: scale(1.2);
                opacity: 0.8;
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .mic-animation svg {
            animation: micPulse 1.5s ease-in-out infinite;
        }
    </style>

    <div class="mb-8">
        <nav class="flex mb-2" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path
                                d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z">
                            </path>
                        </svg>
                        Dashboard
                    </a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <svg class="w-6 h-6 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <span class="ml-1 text-sm font-medium text-slate-800 md:ml-2">Create Profile</span>
                    </div>
                </li>
            </ol>
        </nav>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Create Subject Profile</h1>
                <p class="text-slate-500 mt-1">Add a new individual to the intelligence database</p>
            </div>
            <button type="button" id="globalLangToggleBtn"
                class="flex items-center space-x-2 px-4 py-2 rounded-full bg-white border border-blue-200 text-blue-600 shadow-sm hover:shadow-md transition-all text-sm font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129">
                    </path>
                </svg>
                <span id="globalCurrentLang">Input Language: हिंदी</span>
            </button>
        </div>
    </div>

    <!-- Floating Listening Indicator -->
    <div id="listeningIndicator" class="fixed top-6 left-1/2 transform -translate-x-1/2 hidden z-50">
        <div
            class="flex items-center space-x-3 bg-blue-600 text-white px-5 py-2.5 rounded-full shadow-lg shadow-blue-500/30">
            <div class="mic-animation">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                    </path>
                </svg>
            </div>
            <span class="font-medium" id="listeningStatus">Listening...</span>
        </div>
    </div>

    <form action="/newrecord" method="POST" enctype="multipart/form-data" class="max-w-5xl mx-auto space-y-8">

        <!-- Personal Information -->
        <div class="card-premium p-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Personal Information</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="relative">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">First Name / पहला नाम <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="firstNameInput" name="firstName" class="form-input w-full pr-10"
                            required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="firstNameInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="relative">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Middle Name / मध्य नाम</label>
                    <div class="relative">
                        <input type="text" id="middleNameInput" name="middleName" class="form-input w-full pr-10">
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="middleNameInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="relative">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Last Name / अंतिम नाम <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="lastNameInput" name="lastName" class="form-input w-full pr-10" required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="lastNameInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="relative">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Occupation / पेशा</label>
                    <div class="relative">
                        <input type="text" id="occupationInput" name="occupation" class="form-input w-full pr-10">
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="occupationInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Date of Birth / जन्म तिथि <span
                            class="text-red-500">*</span></label>
                    <input type="date" name="dob" class="form-input w-full" required>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Gender / लिंग <span
                            class="text-red-500">*</span></label>
                    <select name="gender" class="form-input w-full" required>
                        <option value="" disabled selected>Select Gender</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Phone Number / फ़ोन नंबर <span
                            class="text-red-500">*</span></label>
                    <input type="tel" name="mNumber" id="mobileNumber" class="form-input w-full" pattern="[0-9]{10}"
                        required placeholder="10 Digits">
                    <div id="mobileFeedback" class="text-xs mt-1 hidden"></div>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Aadhar Card Number / आधार कार्ड नंबर
                        <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" name="aadharNumber" id="aadharNumber" class="form-input w-full"
                            pattern="[0-9]{12}" required placeholder="12 Digits">
                    </div>
                    <div id="aadharFeedback" class="text-xs mt-1 hidden"></div>
                </div>
            </div>
        </div>

        <!-- Address Information -->
        <div class="card-premium p-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                        </path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Address Information</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Location / पता <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="locationInput" name="address[location]" class="form-input w-full pr-10"
                            placeholder="House No, Area, Landmark" required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="locationInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">City / शहर <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="cityInput" name="address[city]" class="form-input w-full pr-10" required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="cityInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">District / जिला <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="districtInput" name="address[district]" class="form-input w-full pr-10"
                            required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="districtInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">State / राज्य <span
                            class="text-red-500">*</span></label>
                    <div class="relative">
                        <input type="text" id="stateInput" name="address[state]" class="form-input w-full pr-10"
                            required>
                        <button type="button"
                            class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-blue-600 voice-search-btn"
                            data-target="stateInput">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                                </path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Family Details -->
        <div class="card-premium p-8">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center">
                    <div
                        class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 mr-4">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                            </path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold text-slate-800">Family Details</h2>
                </div>
                <button type="button" onclick="addFamilyMember()"
                    class="text-sm font-semibold text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-4 py-2 rounded-lg transition-colors">
                    + Add Member
                </button>
            </div>

            <div id="familyMembers" class="space-y-4">
                <!-- Dynamic entries -->
            </div>
        </div>

        <!-- Images -->
        <div class="card-premium p-8">
            <div class="flex items-center mb-6">
                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-600 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z">
                        </path>
                    </svg>
                </div>
                <h2 class="text-xl font-bold text-slate-800">Profile Images</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Profile Photo (Passport Size)</label>
                    <div
                        class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center hover:bg-slate-50 transition-colors relative group">
                        <input type="file" name="profileImage" accept="image/*"
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                            onchange="previewImage(this, 'profilePreview')">
                        <img id="profilePreview"
                            class="mx-auto h-32 w-32 object-cover rounded-full mb-2 hidden shadow-md">
                        <div id="profilePlaceholder">
                            <svg class="mx-auto h-12 w-12 text-slate-300 mb-2" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                            <p class="text-sm text-slate-500">Click to upload photo</p>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">ID Proof Document</label>
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Documents</label>
                    <div class="space-y-3">
                        <div class="flex items-center space-x-2">
                            <label
                                class="flex-1 cursor-pointer bg-slate-50 border border-slate-200 rounded-lg p-3 text-center hover:bg-slate-100 transition-all">
                                <span class="text-sm text-slate-600 font-medium">Upload ID Proof</span>
                                <input type="file" name="documents" multiple class="hidden">
                            </label>
                            <label
                                class="flex-1 cursor-pointer bg-slate-50 border border-slate-200 rounded-lg p-3 text-center hover:bg-slate-100 transition-all">
                                <span class="text-sm text-slate-600 font-medium">Upload Photos</span>
                                <input type="file" name="images" multiple class="hidden">
                            </label>
                            <button type="button"
                                class="start-face-scan flex-1 bg-purple-600 text-white rounded-lg p-3 hover:bg-purple-700 transition-all font-medium flex items-center justify-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                Scan Face
                            </button>
                        </div>
                    </div>
                    <!-- Hidden Input for Face Descriptor -->
                    <input type="hidden" name="faceDescriptor" id="faceDescriptorInput">
                </div>
            </div>
        </div>

        <!-- Submit Action -->
        <div class="card-premium p-8">
            <div class="grid grid-cols-1 gap-6">
                <div class="col-span-full">
                    <label class="block text-sm font-semibold text-slate-700 mb-1">Notes</label>
                    <textarea name="notes" rows="3" class="form-input w-full"
                        placeholder="Add initial notes or observations..."></textarea>
                </div>
            </div>

            <div class="flex justify-end pt-6 border-t border-slate-100">
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-xl shadow-lg shadow-blue-500/30 transition-all transform hover:-translate-y-0.5">
                    Create Profile
                </button>
            </div>
        </div>

    </form>

    <!-- Initial Search Modal -->
    <div id="speechModal"
        class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6 text-center transform transition-all scale-100">
            <div class="mb-6 relative">
                <div
                    class="w-20 h-20 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4 mic-animation">
                    <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z">
                        </path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-1">Listening...</h3>
                <p class="text-slate-500 text-sm" id="speechStatus">Speak now</p>
            </div>

            <button id="closeModalBtn"
                class="w-full py-2.5 rounded-xl border border-slate-200 text-slate-600 font-semibold hover:bg-slate-50 transition-colors">
                Cancel
            </button>
        </div>
    </div>

    <!-- Face Recognition Modal -->
    <div id="faceModal"
        class="fixed inset-0 bg-slate-900/80 backdrop-blur-md z-50 hidden items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full overflow-hidden">
            <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <h3 class="font-bold text-slate-800 flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                        </path>
                    </svg>
                    Face Scanner
                </h3>
                <button id="closeFaceModal" class="text-slate-400 hover:text-slate-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>
            <div class="p-6 text-center">
                <div class="relative w-full h-64 bg-black rounded-lg overflow-hidden mb-4 shadow-inner">
                    <video id="faceVideo" autoplay muted
                        class="w-full h-full object-cover transform scale-x-[-1]"></video>
                    <div class="absolute inset-0 border-2 border-purple-500/50 rounded-lg pointer-events-none"></div>
                </div>
                <p id="faceStatus" class="mb-4 text-slate-600 font-medium">Initializing AI...</p>
                <button type="button" id="captureFaceBtn"
                    class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-purple-500/30 transition-all">
                    Capture Face
                </button>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <!-- Use JSDelivr and Defer to ensure it loads before our script -->
    <script src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api/dist/face-api.js" defer></script>
    <script src="/js/faceSystem.js" defer></script>
    <script src="/js/suggestions.js"></script>
    <script src="/js/profileVoiceSearch.js"></script>
    <script>
        // Preview logic
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            const placeholder = document.getElementById(previewId.replace('Preview', 'Placeholder'));
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    placeholder.classList.add('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Add Family Member logic
        function addFamilyMember() {
            const container = document.getElementById('familyMembers');
            const div = document.createElement('div');
            div.className = 'grid grid-cols-1 md:grid-cols-7 gap-4 items-center bg-slate-50 p-4 rounded-lg border border-slate-100';
            div.innerHTML = `
            <div class="md:col-span-2">
                <input type="text" name="familyDetails[name][]" placeholder="Name / नाम" class="form-input w-full bg-white">
            </div>
            <div class="md:col-span-2">
                <input type="text" name="familyDetails[relation][]" placeholder="Relation / रिश्ता" class="form-input w-full bg-white">
            </div>
            <div class="md:col-span-2">
                <input type="tel" name="familyDetails[contact][]" placeholder="Contact No." class="form-input w-full bg-white">
            </div>
            <div class="md:col-span-1 text-center">
                <button type="button" onclick="this.closest('div.grid').remove()" class="text-red-500 hover:text-red-700 hover:bg-red-50 p-2 rounded-lg transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            </div>
        `;
            container.appendChild(div);
        }
        // Add one by default
        document.addEventListener('DOMContentLoaded', () => {
            if (document.getElementById('familyMembers').children.length === 0) addFamilyMember();
        });

        // Validations (Aadhar/Mobile) reused from previous logic but simplified for UI
        function validateInput(input, regex, feedbackId, errorMsg) {
            const feedback = document.getElementById(feedbackId);
            // Basic implementation for demonstration
            if (input.value && !regex.test(input.value)) {
                feedback.textContent = errorMsg;
                feedback.classList.remove('hidden', 'text-green-500');
                feedback.classList.add('text-red-500');
                input.classList.add('border-red-300');
            } else {
                feedback.textContent = "Valid";
                feedback.classList.remove('hidden', 'text-red-500');
                feedback.classList.add('text-green-500');
                input.classList.remove('border-red-300');
            }
        }

        document.getElementById('mobileNumber').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 10);
            validateInput(this, /^\d{10}$/, 'mobileFeedback', 'Must be 10 digits');
        });

        document.getElementById('aadharNumber').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 12);
            validateInput(this, /^\d{12}$/, 'aadharFeedback', 'Must be 12 digits');
        });

    </script>