<% layout('./layout/boilerplate') -%>

    <style>
        .profile-hero {
            background: linear-gradient(135deg, #0a0f1e 0%, #0f172a 50%, #0f2040 100%);
            border-bottom: 1px solid rgba(59, 130, 248, 0.15);
        }

        .info-card {
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(59, 130, 246, 0.12);
            border-radius: 1rem;
            backdrop-filter: blur(12px);
            transition: border-color 0.25s, box-shadow 0.25s;
        }

        .info-card:hover {
            border-color: rgba(59, 130, 246, 0.35);
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.06);
        }

        .field-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #475569;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .field-value {
            color: #cbd5e1;
            font-size: 0.97rem;
            font-weight: 500;
            line-height: 1.4;
        }

        .field-value.highlight {
            color: #93c5fd;
            font-family: 'JetBrains Mono', 'Courier New', monospace;
            font-size: 1rem;
            letter-spacing: 0.05em;
        }

        .field-box {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(59, 130, 246, 0.08);
            border-radius: 0.6rem;
            padding: 0.75rem 1rem;
            transition: border-color 0.2s;
        }

        .field-box:hover {
            border-color: rgba(59, 130, 246, 0.2);
        }

        .section-title {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            font-weight: 700;
            color: #60a5fa;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid rgba(59, 130, 246, 0.12);
        }

        .badge-active {
            background: rgba(34, 197, 94, 0.15);
            color: #4ade80;
            border: 1px solid rgba(34, 197, 94, 0.3);
        }

        .badge-pending {
            background: rgba(234, 179, 8, 0.15);
            color: #facc15;
            border: 1px solid rgba(234, 179, 8, 0.3);
        }

        .badge-inactive {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1.1rem;
            border-radius: 0.6rem;
            font-size: 0.82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.18s;
            letter-spacing: 0.01em;
        }

        .btn-edit {
            background: rgba(59, 130, 246, 0.15);
            color: #60a5fa;
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .btn-edit:hover {
            background: rgba(59, 130, 246, 0.28);
            transform: translateY(-1px);
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.25);
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.22);
        }

        .btn-link {
            background: rgba(168, 85, 247, 0.15);
            color: #c084fc;
            border: 1px solid rgba(168, 85, 247, 0.3);
        }

        .btn-link:hover {
            background: rgba(168, 85, 247, 0.28);
            transform: translateY(-1px);
        }

        .photo-ring {
            border: 3px solid rgba(59, 130, 246, 0.6);
            box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.08), 0 0 40px rgba(59, 130, 246, 0.3);
        }

        .stat-pill {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.78rem;
            color: #94a3b8;
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid rgba(59, 130, 246, 0.12);
            border-radius: 999px;
            padding: 0.3rem 0.8rem;
            white-space: nowrap;
        }

        .case-card {
            background: rgba(30, 41, 59, 0.55);
            border-left: 3px solid #3b82f6;
            border-radius: 0 0.75rem 0.75rem 0;
            padding: 1rem 1.25rem;
            transition: background 0.2s, border-left-color 0.2s;
        }

        .case-card:hover {
            background: rgba(30, 41, 59, 0.85);
            border-left-color: #60a5fa;
        }
    </style>

    <!-- HERO HEADER -->
    <div class="profile-hero pt-28 pb-10 px-4">
        <div class="max-w-5xl mx-auto">
            <!-- Breadcrumb -->
            <div class="flex items-center gap-2 text-xs text-slate-500 mb-6">
                <a href="/" class="hover:text-blue-400 transition-colors">Dashboard</a>
                <span>â€º</span>
                <span class="text-slate-300">Profile #<%= record.id %></span>
            </div>

            <div class="flex flex-col md:flex-row items-start gap-8">
                <!-- Profile Photo -->
                <div class="relative flex-shrink-0">
                    <div class="w-36 h-36 rounded-2xl overflow-hidden photo-ring">
                        <img src="<%= record.images.find(img => img.type === 'profile')?.url || '/images/default-profile.png' %>"
                            alt="Profile Photo" class="w-full h-full object-cover"
                            onerror="this.src='/images/default-profile.png'">
                    </div>
                    <!-- Status dot -->
                    <span
                        class="absolute -bottom-2 -right-2 px-2.5 py-0.5 rounded-full text-xs font-bold
          <%= record.status === 'active' ? 'badge-active' : record.status === 'pending' ? 'badge-pending' : 'badge-inactive' %>">
                        <%= record.status.charAt(0).toUpperCase() + record.status.slice(1) %>
                    </span>
                </div>

                <!-- Name & Meta -->
                <div class="flex-1 min-w-0">
                    <h1 class="text-3xl font-bold text-white leading-tight">
                        <%= record.firstNameEnglish %>
                            <%= record.middleNameEnglish || '' %>
                                <%= record.lastNameEnglish || '' %>
                    </h1>
                    <p class="text-blue-300 text-lg mt-0.5">
                        <%= record.firstNameHindi %>
                            <%= record.middleNameHindi || '' %>
                                <%= record.lastNameHindi || '' %>
                    </p>
                    <p class="text-slate-400 text-sm mt-2">
                        <%= record.occupationEnglish || 'Occupation not specified' %>
                            <% if (record.occupationHindi) { %><span class="text-slate-600 ml-1">(<%=
                                        record.occupationHindi %>)</span>
                                <% } %>
                    </p>

                    <!-- Quick stats pills -->
                    <div class="flex flex-wrap gap-2 mt-5">
                        <% if (record.dob) { %>
                            <span class="stat-pill">
                                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <%= new Date(record.dob).toLocaleDateString('en-IN',
                                    {day:'2-digit',month:'short',year:'numeric'}) %>
                            </span>
                            <% } %>
                                <% if (record.gender) { %>
                                    <span
                                        class="stat-pill <%= record.gender === 'male' ? 'text-blue-300' : record.gender === 'female' ? 'text-pink-300' : '' %>">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                        </svg>
                                        <%= record.gender.charAt(0).toUpperCase() + record.gender.slice(1) %>
                                    </span>
                                    <% } %>
                                        <% if (record.address?.cityEnglish) { %>
                                            <span class="stat-pill">
                                                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                                </svg>
                                                <%= record.address.cityEnglish %>
                                                    <% if(record.address.stateEnglish){ %>, <%=
                                                            record.address.stateEnglish %>
                                                            <% } %>
                                            </span>
                                            <% } %>
                                                <% if (record.cases && record.cases.length> 0) { %>
                                                    <span
                                                        class="stat-pill bg-red-500/10 border-red-500/25 text-red-400">
                                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd"
                                                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                                                clip-rule="evenodd" />
                                                        </svg>
                                                        <%= record.cases.length %> Case<%= record.cases.length> 1 ? 's'
                                                                : '' %> Linked
                                                    </span>
                                                    <% } %>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="flex items-center gap-2 flex-shrink-0">
                    <a href="/record/<%= record.id %>/edit" class="action-btn btn-edit">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit
                    </a>
                    <button onclick="showLinkCaseModal()" class="action-btn btn-link">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        Link Case
                    </button>
                    <form action="/record/<%= record.id %>?_method=DELETE" method="POST" class="inline">
                        <button type="submit" class="action-btn btn-delete"
                            onclick="return confirm('Delete this profile permanently?')">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- BODY CONTENT -->
    <div class="max-w-5xl mx-auto px-4 py-10 space-y-6">

        <!-- ROW 1: Personal + Contact -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Personal Information -->
            <div class="info-card p-6">
                <p class="section-title">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    Personal Information
                </p>
                <div class="grid grid-cols-2 gap-3">
                    <div class="field-box">
                        <p class="field-label">Date of Birth</p>
                        <p class="field-value">
                            <%= record.dob ? new Date(record.dob).toLocaleDateString('en-IN',
                                {day:'2-digit',month:'long',year:'numeric'}) : '—' %>
                        </p>
                    </div>
                    <div class="field-box">
                        <p class="field-label">Gender</p>
                        <p class="field-value capitalize flex items-center gap-2">
                            <span
                                class="w-2 h-2 rounded-full inline-block <%= record.gender === 'male' ? 'bg-blue-400' : record.gender === 'female' ? 'bg-pink-400' : 'bg-slate-500' %>"></span>
                            <%= record.gender || '—' %>
                        </p>
                    </div>
                    <div class="col-span-2 field-box">
                        <p class="field-label">Occupation</p>
                        <p class="field-value">
                            <%= record.occupationEnglish || '—' %>
                                <% if (record.occupationHindi) { %><span class="text-slate-500 text-sm ml-2">(<%=
                                            record.occupationHindi %>)</span>
                                    <% } %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="info-card p-6">
                <p class="section-title">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    Contact & Identity
                </p>
                <div class="grid grid-cols-1 gap-3">
                    <div class="field-box flex items-center gap-3">
                        <div
                            class="w-9 h-9 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <div>
                            <p class="field-label">Mobile Number</p>
                            <p class="field-value highlight">
                                <%= record.mNumber || '\u2014' %>
                            </p>
                        </div>
                    </div>
                    <div class="field-box flex items-center gap-3">
                        <div
                            class="w-9 h-9 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0" />
                            </svg>
                        </div>
                        <div>
                            <p class="field-label">Aadhar Number</p>
                            <p class="field-value highlight">
                                <% if(record.aadharNumber && record.aadharNumber.length===12) { %>
                                    <%= record.aadharNumber.slice(0,4) %>&nbsp;<%= record.aadharNumber.slice(4,8) %>
                                            &nbsp;<%= record.aadharNumber.slice(8,12) %>
                                                <% } else { %>
                                                    <%= record.aadharNumber || '\u2014' %>
                                                        <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ROW 2: Address -->
        <div class="info-card p-6">
            <p class="section-title">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Address
            </p>
            <% const addrParts=[record.address?.locationEnglish, record.address?.cityEnglish,
                record.address?.districtEnglish, record.address?.stateEnglish].filter(Boolean); %>
                <% if(addrParts.length) { %>
                    <div class="field-box mb-4 flex items-center gap-3">
                        <svg class="w-4 h-4 text-blue-400 flex-shrink-0" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <p class="field-value text-slate-300">
                            <%= addrParts.join(', ') %></p>
            </div>
            <% } %>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                <div class="field-box">
                    <p class="field-label">Area / Locality</p>
                    <p class="field-value"><%= record.address?.locationEnglish || ' \u2014' %>
                                <% if(record.address?.locationHindi){ %><br><span class="text-slate-500 text-xs">
                                        <%= record.address.locationHindi %>
                                    </span>
                                    <% } %>
                        </p>
                    </div>
                    <div class="field-box">
                        <p class="field-label">City</p>
                        <p class="field-value">
                            <%= record.address?.cityEnglish || '\u2014' %>
                                <% if(record.address?.cityHindi){ %><br><span class="text-slate-500 text-xs">
                                        <%= record.address.cityHindi %>
                                    </span>
                                    <% } %>
                        </p>
                    </div>
                    <div class="field-box">
                        <p class="field-label">District</p>
                        <p class="field-value">
                            <%= record.address?.districtEnglish || '\u2014' %>
                                <% if(record.address?.districtHindi){ %><br><span class="text-slate-500 text-xs">
                                        <%= record.address.districtHindi %>
                                    </span>
                                    <% } %>
                        </p>
                    </div>
                    <div class="field-box">
                        <p class="field-label">State</p>
                        <p class="field-value">
                            <%= record.address?.stateEnglish || '\u2014' %>
                                <% if(record.address?.stateHindi){ %><br><span class="text-slate-500 text-xs">
                                        <%= record.address.stateHindi %>
                                    </span>
                                    <% } %>
        </p>
    </div>
    </div>
    </div>

    <!-- ROW 3: Appearance -->
    <div class="info-card p-6">
        <p class="section-title">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            Physical Appearance
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-5">
            <div>
                <p class="field-label">Height</p>
                <p class="field-value">
                    <%= record.appearance?.height ? record.appearance.height + ' cm' : 'â€”' %>
                </p>
            </div>
            <div>
                <p class="field-label">Weight</p>
                <p class="field-value">
                    <%= record.appearance?.weight ? record.appearance.weight + ' kg' : 'â€”' %>
                </p>
            </div>
            <div>
                <p class="field-label">Build</p>
                <p class="field-value capitalize">
                    <%= record.appearance?.build || 'â€”' %>
                </p>
            </div>
            <div>
                <p class="field-label">Complexion</p>
                <p class="field-value capitalize">
                    <%= record.appearance?.complexion || 'â€”' %>
                </p>
            </div>
        </div>
        <% const hasDistinctive=record.appearance?.facialFeatures || record.appearance?.scars ||
            record.appearance?.tattoos || record.appearance?.otherFeatures; %>
            <% if (hasDistinctive) { %>
                <div class="border-t border-blue-900/40 pt-4 grid grid-cols-2 md:grid-cols-4 gap-5">
                    <div>
                        <p class="field-label">Facial Features</p>
                        <p class="field-value text-sm">
                            <%= record.appearance?.facialFeatures || 'â€”' %>
                        </p>
                    </div>
                    <div>
                        <p class="field-label">Scars / Marks</p>
                        <p class="field-value text-sm">
                            <%= record.appearance?.scars || 'â€”' %>
                        </p>
                    </div>
                    <div>
                        <p class="field-label">Tattoos</p>
                        <p class="field-value text-sm">
                            <%= record.appearance?.tattoos || 'â€”' %>
                        </p>
                    </div>
                    <div>
                        <p class="field-label">Other</p>
                        <p class="field-value text-sm">
                            <%= record.appearance?.otherFeatures || 'â€”' %>
                        </p>
                    </div>
                </div>
                <% } %>
    </div>

    <!-- ROW 4: Family Details -->
    <div class="info-card p-6">
        <p class="section-title">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Family Details
        </p>
        <% if (record.familyDetails && record.familyDetails.length> 0) { %>
            <div class="space-y-3">
                <% record.familyDetails.forEach(member=> { %>
                    <div class="flex flex-col md:flex-row gap-6 py-3 border-b border-slate-800 last:border-0">
                        <div class="flex-1">
                            <p class="field-label">Name</p>
                            <p class="field-value">
                                <%= member.name?.english || 'â€”' %>
                                    <% if (member.name?.hindi) { %><span class="text-slate-500 text-sm ml-1">(<%=
                                                member.name.hindi %>)</span>
                                        <% } %>
                            </p>
                        </div>
                        <div class="flex-1">
                            <p class="field-label">Relation</p>
                            <p class="field-value capitalize">
                                <%= member.relation?.english || 'â€”' %>
                                    <% if (member.relation?.hindi) { %><span class="text-slate-500 text-sm ml-1">(
                                            <%= member.relation.hindi %>)
                                        </span>
                                        <% } %>
                            </p>
                        </div>
                        <div class="flex-1">
                            <p class="field-label">Contact</p>
                            <p class="field-value font-mono text-blue-300">
                                <%= member.contact || 'â€”' %>
                            </p>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <p class="text-slate-600 italic text-sm">No family details recorded</p>
                <% } %>
    </div>

    <!-- ROW 5: ID Document -->
    <div class="info-card p-6">
        <p class="section-title">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0" />
            </svg>
            Identity Documents
        </p>
        <% const idDoc=record.images?.find(img=> img.type === 'identification'); %>
            <% if (idDoc) { %>
                <div class="flex flex-wrap gap-4">
                    <div class="relative group cursor-pointer" onclick="window.open('<%= idDoc.url %>', '_blank')">
                        <img src="<%= idDoc.url %>" alt="ID Document"
                            class="h-44 w-auto object-cover rounded-xl border border-blue-500/20 group-hover:border-blue-500/60 transition-all shadow-lg"
                            onerror="this.src='/images/default-document.png'">
                        <div
                            class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-all rounded-xl flex items-center justify-center">
                            <span class="text-white text-xs font-semibold">Click to view</span>
                        </div>
                    </div>
                </div>
                <% } else { %>
                    <p class="text-slate-600 italic text-sm">No identity documents uploaded</p>
                    <% } %>
    </div>

    <!-- ROW 6: Linked Cases -->
    <div class="info-card p-6">
        <div class="flex items-center justify-between mb-5">
            <p class="section-title mb-0 flex-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Linked Cases
            </p>
            <button onclick="showLinkCaseModal()" class="action-btn btn-link text-xs">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Link New Case
            </button>
        </div>
        <% if (record.cases && record.cases.length> 0) { %>
            <div class="space-y-3">
                <% record.cases.forEach(caseLink=> { %>
                    <div class="case-card">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <div class="flex items-center gap-2 flex-wrap mb-1">
                                    <span class="text-blue-300 font-bold text-sm">Case #<%= caseLink.case.caseNumber %>
                                    </span>
                                    <span
                                        class="text-xs px-2 py-0.5 rounded-full
                <%= caseLink.case.status === 'active' ? 'badge-active' : caseLink.case.status === 'pending' ? 'badge-pending' : 'badge-inactive' %>">
                                        <%= caseLink.case.status %>
                                    </span>
                                    <span
                                        class="text-xs px-2 py-0.5 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20">
                                        Role: <%= caseLink.role %>
                                    </span>
                                </div>
                                <% if (caseLink.case.description?.english) { %>
                                    <p class="text-slate-400 text-sm mt-1">
                                        <%= caseLink.case.description.english %>
                                    </p>
                                    <% } %>
                                        <% if (caseLink.case.location) { %>
                                            <p class="text-slate-600 text-xs mt-1">
                                                ðŸ“ <%= caseLink.case.location?.district?.english || '' %>
                                                    <% if (caseLink.case.location?.state?.english) { %>, <%=
                                                            caseLink.case.location.state.english %>
                                                            <% } %>
                                            </p>
                                            <% } %>
                            </div>
                            <div class="flex gap-2 flex-shrink-0">
                                <a href="/cases/<%= caseLink.case._id %>" class="action-btn btn-edit text-xs">View</a>
                                <button onclick="unlinkCase('<%= record.id %>', '<%= caseLink.case._id %>')"
                                    class="action-btn btn-delete text-xs">Unlink</button>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="flex flex-col items-center py-10 text-slate-600">
                    <svg class="w-10 h-10 mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <p class="text-sm italic">No cases linked to this profile</p>
                </div>
                <% } %>
    </div>

    </div>

    <!-- ======================== LINK CASE MODAL ======================== -->
    <div id="linkCaseModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden items-center justify-center z-50">
        <div
            class="bg-[#0f172a] border border-blue-500/20 rounded-2xl p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto shadow-2xl">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-bold text-blue-300 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    Link Profile to Case
                </h3>
                <button onclick="hideLinkCaseModal()" class="text-slate-500 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <form action="/record/<%= record.id %>/link-case" method="POST" class="space-y-5" id="linkCaseFormEl">
                <div class="relative">
                    <label class="field-label block mb-1">Case Number</label>
                    <input type="text" id="caseNumberInput" name="caseNumber" placeholder="Enter case number..."
                        autocomplete="off"
                        class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2.5 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all"
                        required>
                    <div id="caseSuggestions"
                        class="absolute z-50 w-full mt-1 bg-[#0f172a] border border-blue-500/20 rounded-xl shadow-xl hidden max-h-56 overflow-y-auto">
                    </div>
                </div>

                <div>
                    <label class="field-label block mb-1">Role in Case</label>
                    <select name="role" id="roleSelect"
                        class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2.5 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all"
                        required>
                        <option value="" disabled selected>Select role...</option>
                        <option value="accused">Accused</option>
                        <option value="victim">Victim</option>
                        <option value="witness">Witness</option>
                        <option value="complainant">Complainant</option>
                    </select>
                </div>

                <div>
                    <label class="field-label block mb-1">Case Details</label>
                    <textarea name="details" rows="3" placeholder="Describe this person's involvement..."
                        class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2.5 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all resize-none"></textarea>
                </div>

                <div>
                    <label class="field-label block mb-1">Articles / Sections</label>
                    <div class="space-y-2" id="articlesContainer">
                        <div class="flex gap-2">
                            <input type="text" name="articles[]" placeholder="e.g. IPC 302"
                                class="flex-1 bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                            <button type="button" onclick="addArticleField()" class="action-btn btn-link">+ Add</button>
                        </div>
                    </div>
                </div>

                <!-- Court Details -->
                <div class="border-t border-slate-800 pt-4 space-y-4">
                    <p class="field-label text-blue-400">Court Details (Optional)</p>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="field-label block mb-1">Court Name</label>
                            <input type="text" name="courtName" placeholder="Court name..."
                                class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                        </div>
                        <div>
                            <label class="field-label block mb-1">Court Case No.</label>
                            <input type="text" name="courtCaseNumber" placeholder="Case number..."
                                class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                        </div>
                        <div>
                            <label class="field-label block mb-1">Next Hearing</label>
                            <input type="date" name="nextHearingDate"
                                class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                        </div>
                        <div>
                            <label class="field-label block mb-1">Judge</label>
                            <input type="text" name="judgeName" placeholder="Judge name..."
                                class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                        </div>
                        <div class="col-span-2">
                            <label class="field-label block mb-1">Court Status</label>
                            <select name="courtStatus"
                                class="w-full bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
                                <option value="" disabled selected>Select status...</option>
                                <option value="pending">Pending</option>
                                <option value="ongoing">Ongoing</option>
                                <option value="completed">Completed</option>
                                <option value="appealed">Appealed</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" onclick="hideLinkCaseModal()" class="action-btn btn-delete">Cancel</button>
                    <button type="submit" class="action-btn btn-link">Link Case</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showLinkCaseModal() {
            const modal = document.getElementById('linkCaseModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
        function hideLinkCaseModal() {
            const modal = document.getElementById('linkCaseModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }
        document.getElementById('linkCaseModal').addEventListener('click', function (e) {
            if (e.target === this) hideLinkCaseModal();
        });

        async function unlinkCase(profileId, caseId) {
            if (!confirm('Unlink this case?')) return;
            try {
                const response = await fetch(`/record/${profileId}/unlink-case/${caseId}`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (response.ok) { showNotification('Case unlinked successfully', 'success'); window.location.reload(); }
                else showNotification(data.error || 'Failed to unlink case', 'error');
            } catch (error) { showNotification('Failed to unlink case', 'error'); }
        }

        function showNotification(message, type = 'success') {
            const n = document.createElement('div');
            n.className = `fixed top-4 right-4 px-5 py-3 rounded-xl shadow-xl z-[100] text-sm font-semibold ${type === 'success' ? 'bg-green-500/20 text-green-300 border border-green-500/30' : 'bg-red-500/20 text-red-300 border border-red-500/30'
                }`;
            n.textContent = message;
            document.body.appendChild(n);
            setTimeout(() => n.remove(), 3000);
        }

        document.getElementById('linkCaseFormEl').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const profileId = '<%= record.id %>';
            const articles = Array.from(formData.getAll('articles[]')).filter(a => a.trim()).map(a => ({ section: a }));
            const courtDetails = {
                courtName: formData.get('courtName'),
                caseNumber: formData.get('courtCaseNumber'),
                nextHearingDate: formData.get('nextHearingDate'),
                judgeName: formData.get('judgeName'),
                status: formData.get('courtStatus')
            };
            try {
                const response = await fetch(`/record/${profileId}/link-case`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        caseNumber: formData.get('caseNumber'),
                        role: formData.get('role'),
                        details: formData.get('details'),
                        articles, courtDetails
                    })
                });
                const data = await response.json();
                if (response.ok) { showNotification('Case linked successfully', 'success'); window.location.reload(); }
                else showNotification(data.error || 'Failed to link case', 'error');
            } catch (error) { showNotification('Failed to link case', 'error'); }
        });

        document.getElementById('caseNumberInput').addEventListener('input', async function (e) {
            const input = e.target.value;
            const sc = document.getElementById('caseSuggestions');
            if (!input) { sc.classList.add('hidden'); return; }
            try {
                const response = await fetch(`/api/suggestions?type=caseNumber&query=${encodeURIComponent(input)}`);
                const data = await response.json();
                if (data && data.length > 0) {
                    sc.innerHTML = data.map(c => `
        <div class="p-3 hover:bg-blue-500/10 cursor-pointer transition-all text-sm" onclick="selectCase('${c.caseNumber}')">
          <div class="text-white font-semibold">#${c.caseNumber}</div>
          <div class="text-slate-400 text-xs">${c.description?.english || 'No description'}</div>
        </div>
      `).join('');
                } else {
                    sc.innerHTML = '<div class="p-3 text-slate-500 text-sm">No cases found</div>';
                }
                sc.classList.remove('hidden');
            } catch { sc.innerHTML = '<div class="p-3 text-red-400 text-sm">Error fetching suggestions</div>'; sc.classList.remove('hidden'); }
        });
        function selectCase(caseNumber) {
            document.getElementById('caseNumberInput').value = caseNumber;
            document.getElementById('caseSuggestions').classList.add('hidden');
        }
        document.addEventListener('click', function (e) {
            const sc = document.getElementById('caseSuggestions');
            const inp = document.getElementById('caseNumberInput');
            if (!inp.contains(e.target) && !sc.contains(e.target)) sc.classList.add('hidden');
        });

        function addArticleField() {
            const container = document.getElementById('articlesContainer');
            const div = document.createElement('div');
            div.className = 'flex gap-2';
            div.innerHTML = `
    <input type="text" name="articles[]" placeholder="e.g. IPC 302"
           class="flex-1 bg-slate-800/60 border border-blue-500/20 rounded-xl px-4 py-2 text-slate-100 text-sm focus:outline-none focus:border-blue-400 transition-all">
    <button type="button" onclick="this.parentElement.remove()" class="action-btn btn-delete text-xs">Remove</button>
  `;
            container.appendChild(div);
        }

        document.getElementById('roleSelect').addEventListener('change', function (e) {
            const sec = document.getElementById('arrestDetailsSection');
            if (sec) {
                e.target.value === 'accused' ? sec.classList.remove('hidden') : sec.classList.add('hidden');
            }
        });
        const isArrestedEl = document.getElementById('isArrested');
        if (isArrestedEl) {
            isArrestedEl.addEventListener('change', function (e) {
                const af = document.getElementById('arrestFields');
                if (af) e.target.checked ? af.classList.remove('hidden') : af.classList.add('hidden');
            });
        }
    </script>
