<% layout('./layout/boilerplate') -%>

<<<<<<< HEAD
<div class="pt-20">
    <div class="glass-effect rounded-lg p-8 max-w-4xl mx-auto">
        <div class="flex justify-between items-start mb-8">
            <h1 class="text-3xl font-nasa text-blue-400">Edit Record #<%= record.id %></h1>
            <a href="/record/<%= record.id %>" 
               class="bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 font-nasa px-4 py-2 rounded-md transition-all">
                Back to Record
            </a>
        </div>

        <form action="/record/<%= record.id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="space-y-8">
            <!-- Personal Information Section -->
            <div class="space-y-6">
                <h2 class="text-xl font-nasa text-blue-400/80">Personal Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name Fields -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">First Name / पहला नाम</label>
                        <input type="text" 
                               name="firstName" 
                               value="<%= record.firstNameEnglish || record.firstNameHindi %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Middle Name / मध्य नाम</label>
                        <input type="text" 
                               name="middleName" 
                               value="<%= record.middleNameEnglish || record.middleNameHindi || '' %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Last Name / अंतिम नाम</label>
                        <input type="text" 
                               name="lastName" 
                               value="<%= record.lastNameEnglish || record.lastNameHindi %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>

                    <!-- Occupation & DOB -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Occupation / पेशा</label>
                        <input type="text" 
                               name="occupation" 
                               value="<%= record.occupationEnglish || record.occupationHindi %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Date of Birth</label>
                        <input type="date" 
                               name="dob" 
                               value="<%= record.dob?.toISOString().split('T')[0] %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>

                    <!-- Gender & Aadhar Number -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Gender</label>
                        <select name="gender" 
                                required
                                class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <option value="male" <%= record.gender === 'male' ? 'selected' : '' %>>Male / पुरुष</option>
                            <option value="female" <%= record.gender === 'female' ? 'selected' : '' %>>Female / महिला</option>
                            <option value="other" <%= record.gender === 'other' ? 'selected' : '' %>>Other / अन्य</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Aadhar Number / आधार नंबर</label>
                        <input type="text" 
                               name="aadharNumber" 
                               value="<%= record.aadharNumber %>"
                               pattern="[0-9]{12}"
                               maxlength="12"
                               placeholder="Enter 12-digit Aadhar number"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>

                    <!-- Contact Information -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Mobile Number</label>
                        <input type="text" 
                               name="mNumber" 
                               value="<%= record.mNumber %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                </div>
            </div>

            <!-- Address Section -->
            <div class="space-y-6">
                <h2 class="text-xl font-nasa text-blue-400/80">Address Information</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Location / स्थान</label>
                        <input type="text" 
                               name="address[location]" 
                               value="<%= record.address.locationEnglish || record.address.locationHindi %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">City / शहर</label>
                        <input type="text" 
                               name="address[city]" 
                               value="<%= record.address.cityEnglish || record.address.cityHindi %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">District / जिला</label>
                        <input type="text" 
                               name="address[district]" 
                               value="<%= record.address.districtEnglish || record.address.districtHindi %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">State / राज्य</label>
                        <input type="text" 
                               name="address[state]" 
                               value="<%= record.address.stateEnglish || record.address.stateHindi %>"
                               required
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                </div>
            </div>

            <!-- Physical Appearance -->
            <div class="space-y-6">
                <h2 class="text-xl font-nasa text-blue-400/80">Physical Appearance</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Height (cm)</label>
                        <input type="number" 
                               name="appearance[height]" 
                               value="<%= record.appearance?.height %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Weight (kg)</label>
                        <input type="number" 
                               name="appearance[weight]" 
                               value="<%= record.appearance?.weight %>"
                               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Complexion</label>
                        <select name="appearance[complexion]"
                                class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <option value="fair" <%= record.appearance?.complexion === 'fair' ? 'selected' : '' %>>Fair / गोरा</option>
                            <option value="medium" <%= record.appearance?.complexion === 'medium' ? 'selected' : '' %>>Medium / साँवला</option>
                            <option value="dark" <%= record.appearance?.complexion === 'dark' ? 'selected' : '' %>>Dark / काला</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Build</label>
                        <select name="appearance[build]"
                                class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <option value="slim" <%= record.appearance?.build === 'slim' ? 'selected' : '' %>>Slim / पतला</option>
                            <option value="average" <%= record.appearance?.build === 'average' ? 'selected' : '' %>>Average / सामान्य</option>
                            <option value="athletic" <%= record.appearance?.build === 'athletic' ? 'selected' : '' %>>Athletic / एथलेटिक</option>
                            <option value="heavy" <%= record.appearance?.build === 'heavy' ? 'selected' : '' %>>Heavy / भारी</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Images Section -->
            <div class="space-y-6">
                <h2 class="text-xl font-nasa text-blue-400/80">Update Images</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Profile Image -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">Profile Image</label>
                        <div class="relative">
                            <input type="file" 
                                   name="profileImage" 
                                   accept="image/*"
                                   class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <% if (record.images?.find(img => img.type === 'profile')) { %>
                                <div class="mt-2">
                                    <img src="<%= record.images.find(img => img.type === 'profile').url %>" 
                                         alt="Current Profile Image"
                                         class="w-32 h-32 object-cover rounded-lg">
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- ID Proof -->
                    <div class="space-y-2">
                        <label class="block text-gray-400 mb-2">ID Proof</label>
                        <div class="relative">
                            <input type="file" 
                                   name="idProof" 
                                   accept="image/*"
                                   class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <% if (record.images?.find(img => img.type === 'identification')) { %>
                                <div class="mt-2">
                                    <img src="<%= record.images.find(img => img.type === 'identification').url %>" 
                                         alt="Current ID Proof"
                                         class="w-32 h-32 object-cover rounded-lg">
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Family Details Section -->
            <div class="space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="text-xl font-nasa text-blue-400/80">Family Details</h2>
                    <button type="button" 
                            onclick="addFamilyMember()"
                            class="bg-blue-500/20 hover:bg-blue-500/30 text-blue-400 font-nasa px-4 py-2 rounded-md transition-all">
                        + Add Family Member
                    </button>
                </div>
                <div id="familyMembers" class="space-y-4">
                    <% record.familyDetails?.forEach((member, index) => { %>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-4 glass-effect rounded-lg">
                            <input type="text" 
                                   name="familyDetails[name][]" 
                                   value="<%= member.name.english || member.name.hindi %>"
                                   placeholder="Name / नाम"
                                   class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <input type="text" 
                                   name="familyDetails[relation][]" 
                                   value="<%= member.relation.english || member.relation.hindi %>"
                                   placeholder="Relation / रिश्ता"
                                   class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                            <div class="flex items-center space-x-2">
                                <input type="text" 
                                       name="familyDetails[contact][]" 
                                       value="<%= member.contact %>"
                                       placeholder="Contact / संपर्क"
                                       class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
                                <button type="button" 
                                        onclick="this.parentElement.parentElement.remove()"
                                        class="bg-red-500/20 hover:bg-red-500/30 text-red-400 p-2 rounded-md transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-center pt-6">
                <button type="submit" 
                        class="bg-blue-500 hover:bg-blue-600 text-white font-nasa px-8 py-3 rounded-md transition-all transform hover:scale-105">
                    Update Record
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function addFamilyMember() {
    const container = document.getElementById('familyMembers');
    const memberDiv = document.createElement('div');
    memberDiv.className = 'grid grid-cols-1 md:grid-cols-3 gap-4 p-4 glass-effect rounded-lg';
    memberDiv.innerHTML = `
        <input type="text" 
               name="familyDetails[name][]" 
               placeholder="Name / नाम"
               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
        <input type="text" 
               name="familyDetails[relation][]" 
               placeholder="Relation / रिश्ता"
               class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
        <div class="flex items-center space-x-2">
            <input type="text" 
                   name="familyDetails[contact][]" 
                   placeholder="Contact / संपर्क"
                   class="w-full bg-space-dark/50 border border-blue-400/30 rounded-md px-4 py-2 focus:outline-none focus:border-blue-400 transition-all text-gray-100">
            <button type="button" 
                    onclick="this.parentElement.parentElement.remove()"
                    class="bg-red-500/20 hover:bg-red-500/30 text-red-400 p-2 rounded-md transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
=======
    <style>
        .edit-page-bg {
            background: linear-gradient(160deg, #0a0f1e 0%, #0f172a 60%, #0d1b35 100%);
            min-height: 100vh;
        }

        .edit-card {
            background: rgba(15, 23, 42, 0.85);
            border: 1px solid rgba(59, 130, 246, 0.14);
            border-radius: 1rem;
            backdrop-filter: blur(14px);
            transition: border-color 0.25s;
        }

        .edit-card:hover {
            border-color: rgba(59, 130, 246, 0.28);
        }

        .section-header {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.14em;
            font-weight: 700;
            color: #60a5fa;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding-bottom: 0.85rem;
            border-bottom: 1px solid rgba(59, 130, 246, 0.12);
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #475569;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .form-input {
            width: 100%;
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(59, 130, 246, 0.18);
            border-radius: 0.6rem;
            padding: 0.65rem 1rem;
            color: #e2e8f0;
            font-size: 0.9rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
            -webkit-appearance: none;
        }

        .form-input:focus {
            border-color: rgba(59, 130, 246, 0.6);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        select.form-input option {
            background: #0f172a;
            color: #e2e8f0;
        }

        input[type="date"].form-input::-webkit-calendar-picker-indicator {
            filter: invert(0.6) sepia(1) saturate(3) hue-rotate(190deg);
            cursor: pointer;
        }

        .form-input::placeholder {
            color: #334155;
        }

        .file-input-wrapper {
            position: relative;
        }

        .file-input-wrapper input[type="file"] {
            width: 100%;
            background: rgba(15, 23, 42, 0.7);
            border: 1px dashed rgba(59, 130, 246, 0.25);
            border-radius: 0.6rem;
            padding: 0.65rem 1rem;
            color: #64748b;
            font-size: 0.85rem;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .file-input-wrapper input[type="file"]:hover {
            border-color: rgba(59, 130, 246, 0.45);
        }

        .photo-thumb {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 0.6rem;
            border: 2px solid rgba(59, 130, 246, 0.3);
            margin-top: 0.75rem;
        }

        .family-row {
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(59, 130, 246, 0.1);
            border-radius: 0.75rem;
            padding: 1rem;
            transition: border-color 0.2s;
        }

        .family-row:hover {
            border-color: rgba(59, 130, 246, 0.25);
        }

        .btn-add {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: rgba(59, 130, 246, 0.12);
            color: #60a5fa;
            border: 1px solid rgba(59, 130, 246, 0.25);
            border-radius: 0.6rem;
            padding: 0.45rem 1rem;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.18s;
        }

        .btn-add:hover {
            background: rgba(59, 130, 246, 0.22);
            transform: translateY(-1px);
        }

        .btn-remove {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 0.5rem;
            width: 36px;
            height: 36px;
            flex-shrink: 0;
            cursor: pointer;
            transition: all 0.18s;
        }

        .btn-remove:hover {
            background: rgba(239, 68, 68, 0.22);
        }

        .btn-submit {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 0.85rem 3rem;
            border-radius: 0.75rem;
            border: none;
            cursor: pointer;
            letter-spacing: 0.04em;
            transition: all 0.2s;
            box-shadow: 0 4px 20px rgba(37, 99, 235, 0.35);
        }

        .btn-submit:hover {
            background: linear-gradient(135deg, #1d4ed8, #1e40af);
            box-shadow: 0 6px 28px rgba(37, 99, 235, 0.5);
            transform: translateY(-2px);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: rgba(30, 41, 59, 0.6);
            color: #94a3b8;
            border: 1px solid rgba(59, 130, 246, 0.14);
            border-radius: 0.6rem;
            padding: 0.5rem 1.1rem;
            font-size: 0.83rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.18s;
        }

        .btn-back:hover {
            background: rgba(30, 41, 59, 0.9);
            color: #e2e8f0;
            border-color: rgba(59, 130, 246, 0.3);
        }
    </style>

    <div class="edit-page-bg pt-24 pb-16 px-4">
        <div class="max-w-4xl mx-auto">

            <!-- Top bar -->
            <div class="flex items-center justify-between mb-8">
                <div>
                    <div class="flex items-center gap-2 text-xs text-slate-500 mb-1">
                        <a href="/" class="hover:text-blue-400 transition-colors">Dashboard</a>
                        <span>›</span>
                        <a href="/record/<%= record.id %>" class="hover:text-blue-400 transition-colors">Profile #<%=
                                record.id %></a>
                        <span>›</span>
                        <span class="text-slate-400">Edit</span>
                    </div>
                    <h1 class="text-2xl font-bold text-white">Edit Profile
                        <span class="text-blue-400 text-lg font-normal ml-2">#<%= record.id %></span>
                    </h1>
                </div>
                <a href="/record/<%= record.id %>" class="btn-back">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back to Profile
                </a>
            </div>

            <form action="/record/<%= record.id %>?_method=PUT" method="POST" enctype="multipart/form-data"
                class="space-y-5">

                <!-- ── PERSONAL INFORMATION ── -->
                <div class="edit-card p-6">
                    <p class="section-header">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        Personal Information
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="form-label">First Name / पहला नाम <span class="text-red-400">*</span></label>
                            <input type="text" name="firstName"
                                value="<%= record.firstNameEnglish || record.firstNameHindi %>" required
                                class="form-input" placeholder="Enter first name">
                        </div>
                        <div>
                            <label class="form-label">Middle Name / मध्य नाम</label>
                            <input type="text" name="middleName"
                                value="<%= record.middleNameEnglish || record.middleNameHindi || '' %>"
                                class="form-input" placeholder="Enter middle name (optional)">
                        </div>
                        <div>
                            <label class="form-label">Last Name / अंतिम नाम <span class="text-red-400">*</span></label>
                            <input type="text" name="lastName"
                                value="<%= record.lastNameEnglish || record.lastNameHindi %>" required
                                class="form-input" placeholder="Enter last name">
                        </div>
                        <div>
                            <label class="form-label">Occupation / पेशा</label>
                            <input type="text" name="occupation"
                                value="<%= record.occupationEnglish || record.occupationHindi %>" class="form-input"
                                placeholder="e.g. Teacher, Driver">
                        </div>
                        <div>
                            <label class="form-label">Date of Birth <span class="text-red-400">*</span></label>
                            <input type="date" name="dob" value="<%= record.dob?.toISOString().split('T')[0] %>"
                                required class="form-input">
                        </div>
                        <div>
                            <label class="form-label">Gender <span class="text-red-400">*</span></label>
                            <select name="gender" required class="form-input">
                                <option value="male" <%=record.gender==='male' ? 'selected' : '' %>>Male / पुरुष
                                </option>
                                <option value="female" <%=record.gender==='female' ? 'selected' : '' %>>Female / महिला
                                </option>
                                <option value="other" <%=record.gender==='other' ? 'selected' : '' %>>Other / अन्य
                                </option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Aadhar Number / आधार नंबर</label>
                            <input type="text" name="aadharNumber" value="<%= record.aadharNumber %>"
                                pattern="[0-9]{12}" maxlength="12" class="form-input font-mono tracking-widest"
                                placeholder="12-digit Aadhar">
                        </div>
                        <div>
                            <label class="form-label">Mobile Number</label>
                            <input type="text" name="mNumber" value="<%= record.mNumber %>" class="form-input font-mono"
                                placeholder="10-digit mobile">
                        </div>
                    </div>
                </div>

                <!-- ── ADDRESS ── -->
                <div class="edit-card p-6">
                    <p class="section-header">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Address Information
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="form-label">Location / Area / स्थान <span
                                    class="text-red-400">*</span></label>
                            <input type="text" name="address[location]"
                                value="<%= record.address.locationEnglish || record.address.locationHindi %>" required
                                class="form-input" placeholder="e.g. Charminar, Main Road">
                        </div>
                        <div>
                            <label class="form-label">City / शहर <span class="text-red-400">*</span></label>
                            <input type="text" name="address[city]"
                                value="<%= record.address.cityEnglish || record.address.cityHindi %>" required
                                class="form-input" placeholder="City name">
                        </div>
                        <div>
                            <label class="form-label">District / जिला <span class="text-red-400">*</span></label>
                            <input type="text" name="address[district]"
                                value="<%= record.address.districtEnglish || record.address.districtHindi %>" required
                                class="form-input" placeholder="District name">
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label">State / राज्य <span class="text-red-400">*</span></label>
                            <input type="text" name="address[state]"
                                value="<%= record.address.stateEnglish || record.address.stateHindi %>" required
                                class="form-input" placeholder="State name">
                        </div>
                    </div>
                </div>

                <!-- ── PHYSICAL APPEARANCE ── -->
                <div class="edit-card p-6">
                    <p class="section-header">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                        Physical Appearance
                    </p>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <div>
                            <label class="form-label">Height (cm)</label>
                            <input type="number" name="appearance[height]" value="<%= record.appearance?.height %>"
                                class="form-input" placeholder="e.g. 170">
                        </div>
                        <div>
                            <label class="form-label">Weight (kg)</label>
                            <input type="number" name="appearance[weight]" value="<%= record.appearance?.weight %>"
                                class="form-input" placeholder="e.g. 65">
                        </div>
                        <div>
                            <label class="form-label">Complexion</label>
                            <select name="appearance[complexion]" class="form-input">
                                <option value="fair" <%=record.appearance?.complexion==='fair' ? 'selected' : '' %>>Fair
                                    / गोरा</option>
                                <option value="medium" <%=record.appearance?.complexion==='medium' ? 'selected' : '' %>
                                    >Medium / साँवला</option>
                                <option value="dark" <%=record.appearance?.complexion==='dark' ? 'selected' : '' %>>Dark
                                    / काला</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Build</label>
                            <select name="appearance[build]" class="form-input">
                                <option value="slim" <%=record.appearance?.build==='slim' ? 'selected' : '' %>>Slim /
                                    पतला</option>
                                <option value="average" <%=record.appearance?.build==='average' ? 'selected' : '' %>
                                    >Average / सामान्य</option>
                                <option value="athletic" <%=record.appearance?.build==='athletic' ? 'selected' : '' %>
                                    >Athletic / एथलेटिक</option>
                                <option value="heavy" <%=record.appearance?.build==='heavy' ? 'selected' : '' %>>Heavy /
                                    भारी</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- ── UPDATE IMAGES ── -->
                <div class="edit-card p-6">
                    <p class="section-header">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        Update Images
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="form-label">Profile Photo</label>
                            <div class="file-input-wrapper">
                                <input type="file" name="profileImage" accept="image/*">
                            </div>
                            <% if (record.images?.find(img=> img.type === 'profile')) { %>
                                <img src="<%= record.images.find(img => img.type === 'profile').url %>"
                                    alt="Current Profile" class="photo-thumb">
                                <p class="text-xs text-slate-500 mt-1">Current photo — upload to replace</p>
                                <% } %>
                        </div>
                        <div>
                            <label class="form-label">ID Proof / आधार / Document</label>
                            <div class="file-input-wrapper">
                                <input type="file" name="idProof" accept="image/*">
                            </div>
                            <% if (record.images?.find(img=> img.type === 'identification')) { %>
                                <img src="<%= record.images.find(img => img.type === 'identification').url %>"
                                    alt="Current ID" class="photo-thumb">
                                <p class="text-xs text-slate-500 mt-1">Current document — upload to replace</p>
                                <% } %>
                        </div>
                    </div>
                </div>

                <!-- ── FAMILY DETAILS ── -->
                <div class="edit-card p-6">
                    <div class="flex items-center justify-between mb-4">
                        <p class="section-header mb-0 flex-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Family Details
                        </p>
                        <button type="button" onclick="addFamilyMember()" class="btn-add ml-4">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 4v16m8-8H4" />
                            </svg>
                            Add Member
                        </button>
                    </div>
                    <div id="familyMembers" class="space-y-3">
                        <% record.familyDetails?.forEach((member, index)=> { %>
                            <div class="family-row grid grid-cols-1 md:grid-cols-3 gap-3">
                                <input type="text" name="familyDetails[name][]"
                                    value="<%= member.name.english || member.name.hindi %>" placeholder="Name / नाम"
                                    class="form-input">
                                <input type="text" name="familyDetails[relation][]"
                                    value="<%= member.relation.english || member.relation.hindi %>"
                                    placeholder="Relation / रिश्ता (e.g. Father)" class="form-input">
                                <div class="flex gap-2 items-center">
                                    <input type="text" name="familyDetails[contact][]" value="<%= member.contact %>"
                                        placeholder="Contact / संपर्क" class="form-input flex-1">
                                    <button type="button" onclick="this.closest('.family-row').remove()"
                                        class="btn-remove" title="Remove">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% if (!record.familyDetails || record.familyDetails.length===0) { %>
                        <p class="text-slate-600 text-sm italic mt-2">No family members added yet. Click "Add Member" to
                            add one.</p>
                        <% } %>
                </div>

                <!-- ── SUBMIT ── -->
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-2">
                    <p class="text-xs text-slate-600 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                            <circle cx="10" cy="10" r="10" /><text x="10" y="14" text-anchor="middle" font-size="12"
                                fill="white">*</text>
                        </svg>
                        Fields marked with <span class="text-red-400">*</span> are required
                    </p>
                    <div class="flex gap-3">
                        <a href="/record/<%= record.id %>" class="btn-back">Cancel</a>
                        <button type="submit" class="btn-submit">
                            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M5 13l4 4L19 7" />
                            </svg>
                            Update Profile
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>

