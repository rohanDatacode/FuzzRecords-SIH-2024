<% layout('./layout/boilerplate') -%>

    <div class="min-h-[80vh] flex items-center justify-center">
        <div class="max-w-xl w-full text-center px-4">

            <div class="mb-8 relative">
                <div class="w-32 h-32 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
                    <svg class="w-16 h-16 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>

                <div class="absolute top-0 right-1/4 animate-bounce delay-100">
                    <span
                        class="text-xs font-bold bg-red-100 text-red-600 px-2 py-1 rounded-full border border-red-200">Error
                        404</span>
                </div>
            </div>

            <h1 class="text-4xl font-bold text-slate-800 mb-4 tracking-tight">
                Page Not Found
            </h1>

            <p class="text-lg text-slate-500 mb-10 leading-relaxed">
                The page you are looking for might have been removed, had its name changed, or is temporarily
                unavailable.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <button onclick="history.back()"
                    class="w-full sm:w-auto px-8 py-3 rounded-xl border-2 border-slate-200 text-slate-600 font-semibold hover:border-slate-300 hover:bg-slate-50 transition-all flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Go Back
                </button>

                <a href="/"
                    class="w-full sm:w-auto px-8 py-3 rounded-xl bg-blue-600 text-white font-bold shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:-translate-y-0.5 transition-all flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                        </path>
                    </svg>
                    Return Home
                </a>
            </div>

            <div class="mt-12 pt-8 border-t border-slate-100">
                <p class="text-sm text-slate-400">
                    If you believe this is a system error, please contact the administrator.
                </p>
            </div>
        </div>
    </div>